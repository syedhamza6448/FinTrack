@model FinTrack.Models.ViewModels.InvestmentViewModel
@{
    ViewData["Title"] = "Investments";
}

<div class="page-header">
    <h1>Investments</h1>
    <p>Track your portfolio performance</p>
</div>

@if (TempData["Success"] != null)
{
    <div style="background:rgba(34,197,94,0.08);border:1px solid rgba(34,197,94,0.2);border-radius:10px;padding:0.75rem 1rem;margin-bottom:1.25rem;color:#22c55e;font-size:0.875rem;">
        ✓ @TempData["Success"]
    </div>
}
@if (TempData["Error"] != null)
{
    <div style="background:rgba(244,63,94,0.08);border:1px solid rgba(244,63,94,0.2);border-radius:10px;padding:0.75rem 1rem;margin-bottom:1.25rem;color:var(--accent);font-size:0.875rem;">
        ✕ @TempData["Error"]
    </div>
}

<!-- Summary Stats -->
<div class="grid-4" style="margin-bottom:1.25rem;">
    <div class="card stat-card">
        <div class="stat-label">Total Invested</div>
        <div class="stat-value">₦@Model.TotalInvested.ToString("N0")</div>
    </div>
    <div class="card stat-card">
        <div class="stat-label">Current Value</div>
        <div class="stat-value">₦@Model.TotalCurrentValue.ToString("N0")</div>
    </div>
    <div class="card stat-card">
        <div class="stat-label">Total Gain/Loss</div>
        <div class="stat-value" style="color:@(Model.TotalGainLoss >= 0 ? "#22c55e" : "var(--accent)");">
            @(Model.TotalGainLoss >= 0 ? "+" : "")₦@Model.TotalGainLoss.ToString("N0")
        </div>
        <div class="stat-change" style="color:@(Model.TotalGainLossPercent >= 0 ? "#22c55e" : "var(--accent)");">
            @(Model.TotalGainLossPercent >= 0 ? "▲" : "▼") @Math.Abs(Model.TotalGainLossPercent)%
        </div>
    </div>
    <div class="card stat-card">
        <div class="stat-label">Dividends Earned</div>
        <div class="stat-value" style="color:#22c55e;">₦@Model.TotalDividends.ToString("N0")</div>
    </div>
</div>

<div style="display:grid;grid-template-columns:1fr 320px;gap:1.25rem;align-items:start;">

    <!-- ── Investment List ── -->
    <div class="card">

        <!-- Filter -->
        <form method="get" asp-action="Index"
              style="display:flex;gap:0.6rem;margin-bottom:1.25rem;flex-wrap:wrap;align-items:center;">
            @{
                var types = new[] { "Stock", "Bond", "Real Estate", "Cash" };
            }
            <select name="assetType" class="input-field"
                    style="width:auto;padding:0.35rem 0.75rem;font-size:0.82rem;">
                <option value="">All Types</option>
                @foreach (var t in types)
                {
                    <option value="@t" selected="@(ViewBag.SelectedType == t)">@t</option>
                }
            </select>
            <button type="submit" class="btn-primary"
                    style="padding:0.35rem 1rem;font-size:0.82rem;border-radius:8px;">
                Filter
            </button>
            <a asp-action="Index" style="font-size:0.82rem;color:var(--text-secondary-dark);align-self:center;">
                Clear
            </a>
        </form>

        @if (!Model.Investments.Any())
        {
            <div style="text-align:center;padding:3rem 1rem;color:var(--text-secondary-dark);">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" style="margin:0 auto 1rem;display:block;opacity:0.4;"><path d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" /></svg>
                <p style="font-size:0.9rem;margin-bottom:0.25rem;">No investments yet</p>
                <p style="font-size:0.8rem;">Add your first investment using the form</p>
            </div>
        }
        else
        {
            <div style="display:flex;flex-direction:column;gap:1rem;">
                @foreach (var item in Model.Investments)
                {
                    <div style="background:var(--bg-card2);border:1px solid var(--border-dark);border-radius:12px;padding:1rem;">
                        <div style="display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:0.75rem;">
                            <div style="display:flex;align-items:center;gap:0.75rem;">
                                <!-- Asset type badge -->
                                <div style="width:40px;height:40px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:0.7rem;font-weight:700;flex-shrink:0;
                                            background:@(item.Investment.AssetType == "Stock" ? "rgba(59,130,246,0.1)" :
                                                                                    item.Investment.AssetType == "Bond" ? "rgba(234,179,8,0.1)" :
                                                                                    item.Investment.AssetType == "Real Estate" ? "rgba(139,92,246,0.1)" :
                                                                                    "rgba(34,197,94,0.1)");
                                    color:@(item.Investment.AssetType == "Stock" ? "#3b82f6" :
                                                                        item.Investment.AssetType == "Bond" ? "#eab308" :
                                                                        item.Investment.AssetType == "Real Estate" ? "#8b5cf6" :
                                                                        "#22c55e");">
                            @(item.Investment.AssetType == "Stock" ? "STK" :
                                                        item.Investment.AssetType == "Bond" ? "BND" :
                                                        item.Investment.AssetType == "Real Estate" ? "RE" : "CSH")
                        </div>
                        <div>
                            <div style="font-weight:600;font-size:0.9rem;">
                                @item.Investment.Name
                                @if (!string.IsNullOrEmpty(item.Investment.Ticker))
                                        {
                                            <span style="font-size:0.72rem;color:var(--text-secondary-dark);margin-left:0.35rem;">
                                                @item.Investment.Ticker
                                            </span>
                                        }
                                    </div>
                                    <div style="font-size:0.75rem;color:var(--text-secondary-dark);">
                                        @item.Investment.AssetType ·
                                        Qty: @item.Investment.Quantity ·
                                        Bought @item.Investment.PurchaseDate.ToString("MMM dd, yyyy")
                                    </div>
                                </div>
                            </div>

                            <!-- Gain/Loss -->
                            <div style="text-align:right;">
                                <div style="font-weight:700;font-size:0.95rem;color:@(item.IsProfit ? "#22c55e" : "var(--accent)");">
                                    @(item.IsProfit ? "+" : "")₦@item.GainLoss.ToString("N0")
                                </div>
                                <div style="font-size:0.75rem;color:@(item.IsProfit ? "#22c55e" : "var(--accent)");">
                                    @(item.IsProfit ? "▲" : "▼") @Math.Abs(item.GainLossPercent)%
                                </div>
                            </div>
                        </div>

                        <!-- Price Details -->
                        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:0.5rem;margin-bottom:0.75rem;">
                            <div style="background:var(--bg-card);border-radius:8px;padding:0.5rem 0.75rem;">
                                <div style="font-size:0.68rem;color:var(--text-secondary-dark);text-transform:uppercase;letter-spacing:0.05em;">Buy Price</div>
                                <div style="font-size:0.85rem;font-weight:600;">₦@item.Investment.BuyPrice.ToString("N2")</div>
                            </div>
                            <div style="background:var(--bg-card);border-radius:8px;padding:0.5rem 0.75rem;">
                                <div style="font-size:0.68rem;color:var(--text-secondary-dark);text-transform:uppercase;letter-spacing:0.05em;">Current Price</div>
                                <div style="font-size:0.85rem;font-weight:600;">₦@item.Investment.CurrentPrice.ToString("N2")</div>
                            </div>
                            <div style="background:var(--bg-card);border-radius:8px;padding:0.5rem 0.75rem;">
                                <div style="font-size:0.68rem;color:var(--text-secondary-dark);text-transform:uppercase;letter-spacing:0.05em;">Current Value</div>
                                <div style="font-size:0.85rem;font-weight:600;">₦@item.CurrentValue.ToString("N0")</div>
                            </div>
                        </div>

                        @if ((item.Investment.DividendEarned ?? 0) > 0)
                        {
                            <div style="font-size:0.78rem;color:#22c55e;margin-bottom:0.75rem;">
                                Dividends earned: ₦@((item.Investment.DividendEarned ?? 0).ToString("N0"))
                            </div>
                        }

                        <!-- Actions -->
                        <div style="display:flex;gap:0.5rem;flex-wrap:wrap;">
                            <button type="button"
                                    onclick="openUpdatePrice(@item.Investment.Id, '@item.Investment.Name', @item.Investment.CurrentPrice)"
                                    style="font-size:0.78rem;padding:0.35rem 0.85rem;border-radius:7px;border:1px solid #3b82f6;color:#3b82f6;background:rgba(59,130,246,0.08);cursor:pointer;font-weight:600;">
                                ↑ Update Price
                            </button>
                            <form asp-action="Delete" asp-controller="Investments" method="post" style="display:inline;">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@item.Investment.Id" />
                                <button type="submit"
                                        onclick="return confirm('Delete this investment?')"
                                        style="font-size:0.78rem;padding:0.35rem 0.85rem;border-radius:7px;border:1px solid rgba(244,63,94,0.3);color:var(--accent);background:rgba(244,63,94,0.06);cursor:pointer;">
                                    Delete
                                </button>
                            </form>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <!-- ── Add Investment Form ── -->
    <div class="card" style="position:sticky;top:76px;">
        <h3 style="font-size:0.95rem;margin-bottom:1.25rem;">Add Investment</h3>

        <form asp-action="Create" asp-controller="Investments" method="post"
              style="display:flex;flex-direction:column;gap:1rem;">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly"
                 style="color:var(--accent);font-size:0.82rem;padding:0.5rem;background:rgba(244,63,94,0.08);border-radius:8px;">
            </div>

            <div>
                <label class="input-label" asp-for="NewInvestment.AssetType">Asset Type</label>
                <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:0.4rem;">
                    @{
                        var assetTypes = new[]
                        {
                                        ("Stock", "#3b82f6"),
                                        ("Bond", "#eab308"),
                                        ("Real Estate", "#8b5cf6"),
                                        ("Cash", "#22c55e")
                                        };
                    }
                    @foreach (var (atype, acolor) in assetTypes)
                    {
                        <label style="cursor:pointer;">
                            <input type="radio" name="NewInvestment.AssetType"
                                   value="@atype" style="display:none;"
                                   id="type_@(atype.Replace(" ", ""))"
                                   @(atype == "Stock" ? "checked" : "") />
                            <div onclick="selectAssetType('@atype')"
                                 id="btn_@(atype.Replace(" ", ""))"
                                 style="text-align:center;padding:0.4rem;border-radius:8px;font-size:0.78rem;font-weight:600;cursor:pointer;transition:all 0.15s;
                                     border:1px solid @(atype == "Stock" ? acolor : "var(--border-dark)");
                                     background:@(atype == "Stock" ? acolor + "18" : "none");
                                     color:@(atype == "Stock" ? acolor : "var(--text-secondary-dark)");">
                                @atype
                            </div>
                        </label>
                    }
                </div>
            </div>

            <div>
                <label class="input-label" asp-for="NewInvestment.Name">Name</label>
                <input asp-for="NewInvestment.Name" class="input-field" placeholder="e.g. Apple Inc." />
                <span asp-validation-for="NewInvestment.Name" style="color:var(--accent);font-size:0.78rem;"></span>
            </div>

            <div>
                <label class="input-label" asp-for="NewInvestment.Ticker">Ticker Symbol (optional)</label>
                <input asp-for="NewInvestment.Ticker" class="input-field" placeholder="e.g. AAPL"
                       style="text-transform:uppercase;" />
            </div>

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.6rem;">
                <div>
                    <label class="input-label" asp-for="NewInvestment.Quantity">Quantity</label>
                    <input asp-for="NewInvestment.Quantity" class="input-field" type="number"
                           placeholder="0" step="0.0001" min="0.0001" />
                    <span asp-validation-for="NewInvestment.Quantity" style="color:var(--accent);font-size:0.78rem;"></span>
                </div>
                <div>
                    <label class="input-label" asp-for="NewInvestment.PurchaseDate">Purchase Date</label>
                    <input asp-for="NewInvestment.PurchaseDate" class="input-field" type="date"
                           value="@DateTime.Today.ToString("yyyy-MM-dd")" />
                </div>
            </div>

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.6rem;">
                <div>
                    <label class="input-label" asp-for="NewInvestment.BuyPrice">Buy Price (₦)</label>
                    <input asp-for="NewInvestment.BuyPrice" class="input-field" type="number"
                           placeholder="0.00" step="0.01" min="0.01" />
                    <span asp-validation-for="NewInvestment.BuyPrice" style="color:var(--accent);font-size:0.78rem;"></span>
                </div>
                <div>
                    <label class="input-label" asp-for="NewInvestment.CurrentPrice">Current Price (₦)</label>
                    <input asp-for="NewInvestment.CurrentPrice" class="input-field" type="number"
                           placeholder="0.00" step="0.01" min="0.01" />
                    <span asp-validation-for="NewInvestment.CurrentPrice" style="color:var(--accent);font-size:0.78rem;"></span>
                </div>
            </div>

            <div>
                <label class="input-label" asp-for="NewInvestment.DividendEarned">Dividends Earned (₦)</label>
                <input asp-for="NewInvestment.DividendEarned" class="input-field" type="number"
                       placeholder="0.00" step="0.01" min="0" value="0" />
            </div>

            <button type="submit" class="btn-primary"
                    style="width:100%;justify-content:center;padding:10px;border-radius:10px;">
                + Add Investment
            </button>
        </form>
    </div>

</div>

<!-- ── Update Price Modal ── -->
<div id="updatePriceModal"
     style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.6);z-index:200;align-items:center;justify-content:center;">
    <div style="background:var(--bg-card);border:1px solid var(--border-dark);border-radius:16px;padding:1.75rem;width:100%;max-width:340px;margin:1rem;">
        <h3 style="font-size:1rem;margin-bottom:0.25rem;">Update Price</h3>
        <p id="updatePriceName" style="font-size:0.82rem;color:var(--text-secondary-dark);margin-bottom:1.25rem;"></p>

        <form asp-action="UpdatePrice" asp-controller="Investments" method="post"
              style="display:flex;flex-direction:column;gap:1rem;">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" id="updatePriceId" />

            <div>
                <label class="input-label">New Current Price (₦)</label>
                <input type="number" name="currentPrice" id="updatePriceInput"
                       class="input-field" placeholder="0.00" step="0.01" min="0.01" />
            </div>

            <div style="display:flex;gap:0.6rem;">
                <button type="submit" class="btn-primary"
                        style="flex:1;justify-content:center;padding:10px;border-radius:10px;">
                    Update
                </button>
                <button type="button" onclick="closeUpdatePrice()"
                        style="flex:1;padding:10px;border-radius:10px;border:1px solid var(--border-dark);background:none;color:var(--text-secondary-dark);cursor:pointer;font-size:0.875rem;">
                    Cancel
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        // Asset type toggle
        const assetColors = {
            'Stock': '#3b82f6',
            'Bond': '#eab308',
            'RealEstate': '#8b5cf6',
            'Cash': '#22c55e'
        };

        function selectAssetType(type) {
            ['Stock', 'Bond', 'RealEstate', 'Cash'].forEach(function (t) {
                const btn = document.getElementById('btn_' + t);
                const radio = document.getElementById('type_' + t);
                if (!btn) return;
                const color = assetColors[t];
                if (t === type.replace(' ', '')) {
                    btn.style.border = '1px solid ' + color;
                    btn.style.background = color + '18';
                    btn.style.color = color;
                    radio.checked = true;
                } else {
                    btn.style.border = '1px solid var(--border-dark)';
                    btn.style.background = 'none';
                    btn.style.color = 'var(--text-secondary-dark)';
                }
            });
        }

        // Update price modal
        function openUpdatePrice(id, name, currentPrice) {
            document.getElementById('updatePriceId').value = id;
            document.getElementById('updatePriceName').textContent = 'Updating: ' + name;
            document.getElementById('updatePriceInput').value = currentPrice;
            const modal = document.getElementById('updatePriceModal');
            modal.style.display = 'flex';
            setTimeout(() => document.getElementById('updatePriceInput').focus(), 100);
        }

        function closeUpdatePrice() {
            document.getElementById('updatePriceModal').style.display = 'none';
        }

        document.getElementById('updatePriceModal').addEventListener('click', function (e) {
            if (e.target === this) closeUpdatePrice();
        });
    </script>
}