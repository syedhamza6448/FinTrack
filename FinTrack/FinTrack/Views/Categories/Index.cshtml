@model FinTrack.Models.ViewModels.CategoryViewModel
@{
    ViewData["Title"] = "Categories";
}

<div class="page-header">
    <h1>Categories</h1>
    <p>Manage your income and expense categories</p>
</div>

@if (TempData["Success"] != null)
{
    <div style="background:rgba(34,197,94,0.08);border:1px solid rgba(34,197,94,0.2);border-radius:10px;padding:0.75rem 1rem;margin-bottom:1.25rem;color:#22c55e;font-size:0.875rem;">
        ✓ @TempData["Success"]
    </div>
}
@if (TempData["Error"] != null)
{
    <div style="background:rgba(244,63,94,0.08);border:1px solid rgba(244,63,94,0.2);border-radius:10px;padding:0.75rem 1rem;margin-bottom:1.25rem;color:var(--accent);font-size:0.875rem;">
        ✕ @TempData["Error"]
    </div>
}

<div style="display:grid;grid-template-columns:1fr 340px;gap:1.25rem;align-items:start;">

    <!-- ── Category List ── -->
    <div>
        <!-- Expense Categories -->
        <div class="card" style="margin-bottom:1.25rem;">
            <h3 style="font-size:0.95rem;margin-bottom:1rem;display:flex;align-items:center;gap:0.5rem;">
                <span style="width:8px;height:8px;border-radius:50%;background:var(--accent);display:inline-block;"></span>
                Expense Categories
            </h3>
            @{
                var expenses = Model.Categories.Where(c => c.Type == "Expense").ToList();
            }
            @if (!expenses.Any())
            {
                <p style="color:var(--text-secondary-dark);font-size:0.85rem;">No expense categories yet.</p>
            }
            else
            {
                <div style="display:flex;flex-wrap:wrap;gap:0.6rem;">
                    @foreach (var cat in expenses)
                    {
                        <div style="display:flex;align-items:center;gap:0.5rem;background:var(--bg-card2);border:1px solid var(--border-dark);border-radius:99px;padding:0.35rem 0.75rem;">
                            <span style="width:8px;height:8px;border-radius:50%;background:@cat.Color;flex-shrink:0;"></span>
                            <span style="font-size:0.82rem;font-weight:500;">@cat.Name</span>
                            @if (!cat.isDefault)
                            {
                                <form asp-action="Delete" asp-controller="Categories" asp-route-prefix="NewCategory" method="post" style="display:inline;margin:0;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@cat.Id" />
                                    <button type="submit"
                                            onclick="return confirm('Delete @cat.Name?')"
                                            style="background:none;border:none;cursor:pointer;color:var(--text-secondary-dark);padding:0;line-height:1;margin-left:2px;"
                                            title="Delete">
                                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                            <line x1="18" y1="6" x2="6" y2="18" />
                                            <line x1="6" y1="6" x2="18" y2="18" />
                                        </svg>
                                    </button>
                                </form>
                            }
                            else
                            {
                                <span style="font-size:0.65rem;color:var(--text-secondary-dark);margin-left:2px;">default</span>
                            }
                        </div>
                    }
                </div>
            }
        </div>

        <!-- Income Categories -->
        <div class="card">
            <h3 style="font-size:0.95rem;margin-bottom:1rem;display:flex;align-items:center;gap:0.5rem;">
                <span style="width:8px;height:8px;border-radius:50%;background:#22c55e;display:inline-block;"></span>
                Income Categories
            </h3>
            @{
                var incomes = Model.Categories.Where(c => c.Type == "Income").ToList();
            }
            @if (!incomes.Any())
            {
                <p style="color:var(--text-secondary-dark);font-size:0.85rem;">No income categories yet.</p>
            }
            else
            {
                <div style="display:flex;flex-wrap:wrap;gap:0.6rem;">
                    @foreach (var cat in incomes)
                    {
                        <div style="display:flex;align-items:center;gap:0.5rem;background:var(--bg-card2);border:1px solid var(--border-dark);border-radius:99px;padding:0.35rem 0.75rem;">
                            <span style="width:8px;height:8px;border-radius:50%;background:@cat.Color;flex-shrink:0;"></span>
                            <span style="font-size:0.82rem;font-weight:500;">@cat.Name</span>
                            @if (!cat.isDefault)
                            {
                                <form asp-action="Delete" asp-controller="Categories" method="post" style="display:inline;margin:0;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@cat.Id" />
                                    <button type="submit"
                                            onclick="return confirm('Delete @cat.Name?')"
                                            style="background:none;border:none;cursor:pointer;color:var(--text-secondary-dark);padding:0;line-height:1;margin-left:2px;"
                                            title="Delete">
                                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                            <line x1="18" y1="6" x2="6" y2="18" />
                                            <line x1="6" y1="6" x2="18" y2="18" />
                                        </svg>
                                    </button>
                                </form>
                            }
                            else
                            {
                                <span style="font-size:0.65rem;color:var(--text-secondary-dark);margin-left:2px;">default</span>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    <!-- ── Add Category Form ── -->
    <div class="card" style="position:sticky;top:76px;">
        <h3 style="font-size:0.95rem;margin-bottom:1.25rem;">Add New Category</h3>

        <form asp-action="Create" asp-controller="Categories" method="post"
              style="display:flex;flex-direction:column;gap:1rem;">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly"
                 style="color:var(--accent);font-size:0.82rem;padding:0.5rem;background:rgba(244,63,94,0.08);border-radius:8px;">
            </div>

            <div>
                <label class="input-label" asp-for="NewCategory.Name">Category Name</label>
                <input asp-for="NewCategory.Name" class="input-field" placeholder="e.g. Groceries" />
                <span asp-validation-for="NewCategory.Name" style="color:var(--accent);font-size:0.78rem;"></span>
            </div>

            <div>
                <label class="input-label" asp-for="NewCategory.Type">Type</label>
                <select asp-for="NewCategory.Type" class="input-field">
                    <option value="">Select type...</option>
                    <option value="Expense">Expense</option>
                    <option value="Income">Income</option>
                </select>
                <span asp-validation-for="NewCategory.Type" style="color:var(--accent);font-size:0.78rem;"></span>
            </div>

            <!-- Icon Picker -->
            <div>
                <label class="input-label">Icon</label>
                <input asp-for="NewCategory.Icon" type="hidden" id="selectedIcon" value="tag" />

                <div style="display:grid;grid-template-columns:repeat(6,1fr);gap:0.4rem;background:var(--bg-card2);border:1px solid var(--border-dark);border-radius:10px;padding:0.6rem;">
                    @{
                        var icons = new[]
                        {
                            ("shoppingCart", "M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 001.95-1.57l1.65-8.42H6"),
                            ("car",          "M5 17H3a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v9a2 2 0 01-2 2h-2m-1 0a2 2 0 11-4 0 2 2 0 014 0zM7 17a2 2 0 11-4 0 2 2 0 014 0z"),
                            ("film",         "M19.82 2H4.18A2.18 2.18 0 002 4.18v15.64A2.18 2.18 0 004.18 22h15.64A2.18 2.18 0 0022 19.82V4.18A2.18 2.18 0 0019.82 2zM7 2v20M17 2v20M2 12h20M2 7h5M2 17h5M17 17h5M17 7h5"),
                            ("zap",          "M13 2L3 14h9l-1 8 10-12h-9l1-8z"),
                            ("pill",         "M10.5 20H4a2 2 0 01-2-2V6a2 2 0 012-2h16a2 2 0 012 2v7"),
                            ("book",         "M4 19.5A2.5 2.5 0 016.5 17H20V3H6.5A2.5 2.5 0 004 5.5v14z"),
                            ("home",         "M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"),
                            ("dollarSign",   "M12 1v22M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"),
                            ("creditCard",   "M1 4h22v16H1zM1 10h22"),
                            ("briefcase",    "M20 7H4a2 2 0 00-2 2v11a2 2 0 002 2h16a2 2 0 002-2V9a2 2 0 00-2-2zM16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"),
                            ("trendUp",      "M23 6l-9.5 9.5-5-5L1 18"),
                            ("building",     "M6 22V4a2 2 0 012-2h8a2 2 0 012 2v18zM2 22h20M14 11h.01M14 7h.01M10 11h.01M10 7h.01"),
                            ("fuel",         "M3 22V8l7-6 7 6v14M10 22V16h4v6"),
                            ("bag",          "M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4zM3 6h18M16 10a4 4 0 01-8 0"),
                            ("tag",          "M20.59 13.41l-7.17 7.17a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82z"),
                            ("target",       "M12 22a10 10 0 100-20 10 10 0 000 20zM12 18a6 6 0 100-12 6 6 0 000 12zM12 14a2 2 0 100-4 2 2 0 000 4z"),
                            ("wallet",       "M20 7H4a2 2 0 00-2 2v10a2 2 0 002 2h16a2 2 0 002-2V9a2 2 0 00-2-2zM16 13a1 1 0 110-2 1 1 0 010 2z"),
                            ("coffee",       "M18 8h1a4 4 0 010 8h-1M2 8h16v9a4 4 0 01-4 4H6a4 4 0 01-4-4V8zM6 1v3M10 1v3M14 1v3"),
                        };
                    }

                    @foreach (var (name, path) in icons)
                    {
                        <button type="button"
                                onclick="selectIcon('@name', this)"
                                title="@name"
                                data-icon="@name"
                                style="width:100%;aspect-ratio:1;border-radius:8px;border:1px solid var(--border-dark);background:none;cursor:pointer;display:flex;align-items:center;justify-content:center;color:var(--text-secondary-dark);transition:all 0.15s;"
                                onmouseover="if(!this.classList.contains('icon-selected')){this.style.borderColor='var(--accent)';this.style.color='var(--accent)'}"
                                onmouseout="if(!this.classList.contains('icon-selected')){this.style.borderColor='var(--border-dark)';this.style.color='var(--text-secondary-dark)'}">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                                <path d="@path" />
                            </svg>
                        </button>
                    }
                </div>

                <div style="font-size:0.75rem;color:var(--text-secondary-dark);margin-top:0.35rem;">
                    Selected: <span id="iconLabel" style="color:var(--accent);font-weight:600;">tag</span>
                </div>
            </div>

            <!-- Color Picker -->
            <div>
                <label class="input-label">Color</label>
                <div style="display:flex;align-items:center;gap:0.5rem;flex-wrap:wrap;">
                    @{
                        var colors = new[] { "#f43f5e", "#3b82f6", "#22c55e", "#eab308", "#8b5cf6", "#f97316", "#ec4899", "#14b8a6", "#64748b", "#94a3b8" };
                    }
                    @foreach (var color in colors)
                    {
                        <button type="button"
                                onclick="selectColor('@color', this)"
                                data-color="@color"
                                style="width:26px;height:26px;border-radius:50%;background:@color;border:2px solid transparent;cursor:pointer;transition:all 0.15s;"
                                title="@color">
                        </button>
                    }
                    <input asp-for="NewCategory.Color"
                           type="color"
                           id="colorPickerInput"
                           style="width:26px;height:26px;border-radius:50%;border:2px solid var(--border-dark);cursor:pointer;padding:1px;background:none;"
                           title="Custom color"
                           onchange="selectColorFromPicker(this.value)" />
                </div>
                <div style="font-size:0.75rem;color:var(--text-secondary-dark);margin-top:0.35rem;">
                    Selected: <span id="colorLabel" style="font-weight:600;color:#f43f5e;">#f43f5e</span>
                </div>
            </div>

            <button type="submit" class="btn-primary"
                    style="width:100%;justify-content:center;padding:10px;border-radius:10px;margin-top:0.25rem;">
                + Add Category
            </button>
        </form>
    </div>

</div> 

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const defaultIcon = document.querySelector('[data-icon="tag"]');
            if (defaultIcon) {
                defaultIcon.classList.add('icon-selected');
                defaultIcon.style.borderColor = 'var(--accent)';
                defaultIcon.style.color = 'var(--accent)';
                defaultIcon.style.background = 'var(--accent-glow)';
            }

            const defaultColor = document.querySelector('[data-color="#f43f5e"]');
            if (defaultColor) {
                defaultColor.style.borderColor = 'white';
                defaultColor.style.transform = 'scale(1.2)';
            }
        });

        function selectIcon(name, btn) {
            document.querySelectorAll('[data-icon]').forEach(function (b) {
                b.classList.remove('icon-selected');
                b.style.borderColor = 'var(--border-dark)';
                b.style.color = 'var(--text-secondary-dark)';
                b.style.background = 'none';
            });

            btn.classList.add('icon-selected');
            btn.style.borderColor = 'var(--accent)';
            btn.style.color = 'var(--accent)';
            btn.style.background = 'var(--accent-glow)';

            document.getElementById('selectedIcon').value = name;
            document.getElementById('iconLabel').textContent = name;
        }

        function selectColor(hex, btn) {
            document.querySelectorAll('[data-color]').forEach(function (b) {
                b.style.borderColor = 'transparent';
                b.style.transform = 'scale(1)';
            });

            btn.style.borderColor = 'white';
            btn.style.transform = 'scale(1.2)';

            document.querySelector('[name="NewCategory.Color"]').value = hex;
            document.getElementById('colorPickerInput').value = hex;
            document.getElementById('colorLabel').textContent = hex;
            document.getElementById('colorLabel').style.color = hex;
        }

        function selectColorFromPicker(hex) {
            document.querySelectorAll('[data-color]').forEach(function (b) {
                b.style.borderColor = 'transparent';
                b.style.transform = 'scale(1)';
            });

            document.querySelector('[name="NewCategory.Color"]').value = hex;
            document.getElementById('colorLabel').textContent = hex;
            document.getElementById('colorLabel').style.color = hex;
        }
    </script>
}