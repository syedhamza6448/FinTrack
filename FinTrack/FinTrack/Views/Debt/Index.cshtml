@model FinTrack.Models.ViewModels.DebtViewModel
@{
    ViewData["Title"] = "Debt";
}

<style>
    .debt-grid {
        display: grid;
        grid-template-columns: 1fr 320px;
        gap: 1.25rem;
        align-items: start;
    }

    .debt-form-sticky {
        position: sticky;
        top: 76px;
    }

    .debt-stats {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1.25rem;
        margin-bottom: 1.25rem;
    }

    .debt-card-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        margin-bottom: 1rem;
    }

    .debt-details-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 0.5rem;
        margin-bottom: 0.75rem;
    }

    @@media (max-width: 1024px) {
        .debt-grid {
            grid-template-columns: 1fr;
        }

        .debt-form-sticky {
            position: static;
        }
    }

    @@media (max-width: 640px) {
        .debt-stats {
            grid-template-columns: repeat(2, 1fr);
        }

        .debt-card-header {
            flex-direction: column;
            gap: 0.5rem;
        }

        .debt-remaining {
            text-align: left !important;
        }

        .debt-details-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .debt-badges {
            flex-wrap: wrap;
        }
    }
</style>

<div class="page-header">
    <h1>Debt Management</h1>
    <p>Track and pay off your debts strategically</p>
</div>

@if (TempData["Success"] != null)
{
    <div style="background:rgba(34,197,94,0.08);border:1px solid rgba(34,197,94,0.2);border-radius:10px;padding:0.75rem 1rem;margin-bottom:1.25rem;color:#22c55e;font-size:0.875rem;">
        ✓ @TempData["Success"]
    </div>
}
@if (TempData["Error"] != null)
{
    <div style="background:rgba(244,63,94,0.08);border:1px solid rgba(244,63,94,0.2);border-radius:10px;padding:0.75rem 1rem;margin-bottom:1.25rem;color:var(--accent);font-size:0.875rem;">
        ✕ @TempData["Error"]
    </div>
}

<!-- Summary Stats -->
<div class="debt-stats">
    <div class="card stat-card">
        <div class="stat-label">Total Debt</div>
        <div class="stat-value" style="color:var(--accent);">₦@Model.TotalDebt.ToString("N0")</div>
    </div>
    <div class="card stat-card">
        <div class="stat-label">Monthly Payments</div>
        <div class="stat-value">₦@Model.TotalMonthlyPayments.ToString("N0")</div>
    </div>
    <div class="card stat-card">
        <div class="stat-label">High Priority</div>
        <div class="stat-value" style="color:@(Model.HighPriorityCount > 0 ? "var(--accent)" : "#22c55e");">
            @Model.HighPriorityCount
        </div>
    </div>
    <div class="card stat-card">
        <div class="stat-label">Total Debts</div>
        <div class="stat-value">@Model.DebtCount</div>
    </div>
</div>

<div class="debt-grid">

    <!-- ── Debt List ── -->
    <div>
        @if (!Model.Debts.Any())
        {
            <div class="card" style="text-align:center;padding:3rem 1rem;color:var(--text-secondary-dark);">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25"
                     style="margin:0 auto 1rem;display:block;opacity:0.4;">
                    <rect x="1" y="4" width="22" height="16" rx="2" />
                    <line x1="1" y1="10" x2="23" y2="10" />
                </svg>
                <p style="font-size:0.9rem;margin-bottom:0.25rem;">No debts tracked</p>
                <p style="font-size:0.8rem;">Add a debt using the form to start tracking</p>
            </div>
        }
        else
        {
            <div style="display:flex;flex-direction:column;gap:1.25rem;">
                @foreach (var item in Model.Debts)
                {
                    var priorityColor = item.Debt.Priority == "High" ? "#f43f5e"
                    : item.Debt.Priority == "Medium" ? "#eab308" : "#22c55e";

                    <div class="card" style="border-left:3px solid @priorityColor;">

                        <!-- Header -->
                        <div class="debt-card-header">
                            <div>
                                <div class="debt-badges" style="display:flex;align-items:center;gap:0.6rem;margin-bottom:0.25rem;">
                                    <span style="font-weight:600;font-size:0.95rem;">@item.Debt.Name</span>
                                    <span style="font-size:0.7rem;padding:0.15rem 0.5rem;border-radius:99px;font-weight:600;
                                                background:@(priorityColor)18;color:@priorityColor;">
                                        @item.Debt.Priority
                                    </span>
                                    <span style="font-size:0.7rem;padding:0.15rem 0.5rem;border-radius:99px;background:var(--bg-card2);border:1px solid var(--border-dark);color:var(--text-secondary-dark);">
                                        @item.Debt.DebtType
                                    </span>
                                </div>
                                <div style="font-size:0.75rem;color:var(--text-secondary-dark);">
                                    Started @item.Debt.StartDate.ToString("MMM dd, yyyy")
                                    @if (item.Debt.InterestRate > 0)
                                    {
                                        <span> · @item.Debt.InterestRate% interest</span>
                                    }
                                    @if (item.Debt.ExpectedPayoffDate != default(DateTime))
                                    {
                                        <span> · Payoff by @item.Debt.ExpectedPayoffDate.ToString("MMM yyyy")</span>
                                    }
                                </div>
                            </div>
                            <div class="debt-remaining" style="text-align:right;">
                                <div style="font-size:0.75rem;color:var(--text-secondary-dark);">Remaining</div>
                                <div style="font-weight:700;font-size:1rem;color:var(--accent);">
                                    ₦@item.Debt.RemainingBalance.ToString("N0")
                                </div>
                            </div>
                        </div>

                        <!-- Progress -->
                        <div style="margin-bottom:0.75rem;">
                            <div style="display:flex;justify-content:space-between;font-size:0.78rem;margin-bottom:0.4rem;">
                                <span style="color:var(--text-secondary-dark);">
                                    ₦@item.PaidOff.ToString("N0") paid off
                                </span>
                                <span style="font-weight:600;color:@priorityColor;">@item.ProgressPercent%</span>
                            </div>
                            <div style="height:8px;background:var(--bg-card2);border-radius:99px;overflow:hidden;">
                                <div style="height:100%;width:@(item.ProgressPercent)%;background:@priorityColor;border-radius:99px;transition:width 0.6s ease;"></div>
                            </div>
                            <div style="display:flex;justify-content:space-between;font-size:0.72rem;color:var(--text-secondary-dark);margin-top:0.3rem;">
                                <span>₦0</span>
                                <span>₦@item.Debt.OriginalAmount.ToString("N0")</span>
                            </div>
                        </div>

                        <!-- Details row -->
                        <div class="debt-details-grid">
                            <div style="background:var(--bg-card2);border-radius:8px;padding:0.5rem 0.75rem;">
                                <div style="font-size:0.68rem;color:var(--text-secondary-dark);text-transform:uppercase;letter-spacing:0.05em;">Original</div>
                                <div style="font-size:0.85rem;font-weight:600;">₦@item.Debt.OriginalAmount.ToString("N0")</div>
                            </div>
                            <div style="background:var(--bg-card2);border-radius:8px;padding:0.5rem 0.75rem;">
                                <div style="font-size:0.68rem;color:var(--text-secondary-dark);text-transform:uppercase;letter-spacing:0.05em;">Monthly</div>
                                <div style="font-size:0.85rem;font-weight:600;">₦@item.Debt.MonthlyPayment.ToString("N0")</div>
                            </div>
                            <div style="background:var(--bg-card2);border-radius:8px;padding:0.5rem 0.75rem;">
                                <div style="font-size:0.68rem;color:var(--text-secondary-dark);text-transform:uppercase;letter-spacing:0.05em;">Months Left</div>
                                <div style="font-size:0.85rem;font-weight:600;">
                                    @(item.Debt.RemainingBalance <= 0 ? "✓ Paid" : item.MonthsRemaining.ToString())
                                </div>
                            </div>
                        </div>

                        <!-- Actions -->
                        <div style="display:flex;gap:0.5rem;flex-wrap:wrap;">
                            @if (item.Debt.RemainingBalance > 0)
                            {
                                <button type="button"
                                        onclick="openPayment(@item.Debt.Id, '@item.Debt.Name', @item.Debt.MonthlyPayment)"
                                        style="font-size:0.78rem;padding:0.35rem 0.85rem;border-radius:7px;border:1px solid #22c55e;color:#22c55e;background:rgba(34,197,94,0.08);cursor:pointer;font-weight:600;">
                                    💳 Make Payment
                                </button>
                            }
                            else
                            {
                                <span style="font-size:0.78rem;padding:0.35rem 0.85rem;border-radius:7px;background:rgba(34,197,94,0.1);color:#22c55e;font-weight:600;">
                                    ✓ Fully Paid Off
                                </span>
                            }
                            <form asp-action="Delete" asp-controller="Debt" method="post" style="display:inline;">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@item.Debt.Id" />
                                <button type="submit"
                                        onclick="return confirm('Remove this debt?')"
                                        style="font-size:0.78rem;padding:0.35rem 0.85rem;border-radius:7px;border:1px solid rgba(244,63,94,0.3);color:var(--accent);background:rgba(244,63,94,0.06);cursor:pointer;">
                                    Delete
                                </button>
                            </form>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <!-- ── Add Debt Form ── -->
    <div class="card debt-form-sticky">
        <h3 style="font-size:0.95rem;margin-bottom:1.25rem;">Add Debt</h3>

        <form asp-action="Create" asp-controller="Debt" method="post"
              style="display:flex;flex-direction:column;gap:1rem;">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly"
                 style="color:var(--accent);font-size:0.82rem;padding:0.5rem;background:rgba(244,63,94,0.08);border-radius:8px;">
            </div>

            <div>
                <label class="input-label" asp-for="NewDebt.Name">Debt Name</label>
                <input asp-for="NewDebt.Name" class="input-field" placeholder="e.g. Car Loan" />
                <span asp-validation-for="NewDebt.Name" style="color:var(--accent);font-size:0.78rem;"></span>
            </div>

            <div>
                <label class="input-label" asp-for="NewDebt.DebtType">Debt Type</label>
                <select asp-for="NewDebt.DebtType" class="input-field">
                    <option value="">Select type...</option>
                    <option value="Mortgage">Mortgage</option>
                    <option value="StudentLoan">Student Loan</option>
                    <option value="CreditCard">Credit Card</option>
                    <option value="Personal">Personal Loan</option>
                    <option value="CarLoan">Car Loan</option>
                    <option value="Other">Other</option>
                </select>
                <span asp-validation-for="NewDebt.DebtType" style="color:var(--accent);font-size:0.78rem;"></span>
            </div>

            <div>
                <label class="input-label" asp-for="NewDebt.Priority">Priority</label>
                <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:0.4rem;">
                    @{
                        var priorities = new[]
                        {
                                        ("High", "#f43f5e"),
                                        ("Medium", "#eab308"),
                                        ("Low", "#22c55e")
                                        };
                    }
                    @foreach (var (priority, pcolor) in priorities)
                    {
                        <label style="cursor:pointer;">
                            <input type="radio" name="NewDebt.Priority" value="@priority"
                                   id="priority_@priority" style="display:none;"
                                   @(priority == "Medium" ? "checked" : "") />
                            <div onclick="selectPriority('@priority')"
                                 id="pbtn_@priority"
                                 style="text-align:center;padding:0.4rem;border-radius:8px;font-size:0.78rem;font-weight:600;cursor:pointer;transition:all 0.15s;
                                     border:1px solid @(priority == "Medium" ? pcolor : "var(--border-dark)");
                                     background:@(priority == "Medium" ? pcolor + "18" : "none");
                                     color:@(priority == "Medium" ? pcolor : "var(--text-secondary-dark)");">
                                @priority
                            </div>
                        </label>
                    }
                </div>
            </div>

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.6rem;">
                <div>
                    <label class="input-label" asp-for="NewDebt.OriginalAmount">Original Amount (₦)</label>
                    <input asp-for="NewDebt.OriginalAmount" class="input-field" type="number"
                           placeholder="0.00" step="0.01" min="0.01" />
                    <span asp-validation-for="NewDebt.OriginalAmount" style="color:var(--accent);font-size:0.78rem;"></span>
                </div>
                <div>
                    <label class="input-label" asp-for="NewDebt.RemainingBalance">Remaining Balance (₦)</label>
                    <input asp-for="NewDebt.RemainingBalance" class="input-field" type="number"
                           placeholder="0.00" step="0.01" min="0.01" />
                    <span asp-validation-for="NewDebt.RemainingBalance" style="color:var(--accent);font-size:0.78rem;"></span>
                </div>
            </div>

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.6rem;">
                <div>
                    <label class="input-label" asp-for="NewDebt.MonthlyPayment">Monthly Payment (₦)</label>
                    <input asp-for="NewDebt.MonthlyPayment" class="input-field" type="number"
                           placeholder="0.00" step="0.01" min="0.01" />
                    <span asp-validation-for="NewDebt.MonthlyPayment" style="color:var(--accent);font-size:0.78rem;"></span>
                </div>
                <div>
                    <label class="input-label" asp-for="NewDebt.InterestRate">Interest Rate (%)</label>
                    <input asp-for="NewDebt.InterestRate" class="input-field" type="number"
                           placeholder="0.00" step="0.01" min="0" max="100" value="0" />
                </div>
            </div>

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.6rem;">
                <div>
                    <label class="input-label" asp-for="NewDebt.StartDate">Start Date</label>
                    <input asp-for="NewDebt.StartDate" class="input-field" type="date"
                           value="@DateTime.Today.ToString("yyyy-MM-dd")" />
                </div>
                <div>
                    <label class="input-label" asp-for="NewDebt.ExpectedPayoffDate">Payoff Date (optional)</label>
                    <input asp-for="NewDebt.ExpectedPayoffDate" class="input-field" type="date" />
                </div>
            </div>

            <button type="submit" class="btn-primary"
                    style="width:100%;justify-content:center;padding:10px;border-radius:10px;">
                + Add Debt
            </button>
        </form>
    </div>

</div>

<!-- ── Make Payment Modal ── -->
<div id="paymentModal"
     style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.6);z-index:200;align-items:center;justify-content:center;">
    <div style="background:var(--bg-card);border:1px solid var(--border-dark);border-radius:16px;padding:1.75rem;width:100%;max-width:340px;margin:1rem;">
        <h3 style="font-size:1rem;margin-bottom:0.25rem;">Make Payment</h3>
        <p id="paymentDebtName" style="font-size:0.82rem;color:var(--text-secondary-dark);margin-bottom:1.25rem;"></p>

        <form asp-action="MakePayment" asp-controller="Debt" method="post"
              style="display:flex;flex-direction:column;gap:1rem;">
            @Html.AntiForgeryToken()
            <input type="hidden" name="DebtId" id="paymentDebtId" />

            <div>
                <label class="input-label">Payment Amount (₦)</label>
                <input type="number" name="Amount" id="paymentAmount"
                       class="input-field" placeholder="0.00" step="0.01" min="0.01" />
                <div style="font-size:0.75rem;color:var(--text-secondary-dark);margin-top:0.25rem;">
                    Suggested monthly payment:
                    <span id="suggestedPayment" style="color:var(--accent);font-weight:600;"></span>
                </div>
            </div>

            <div style="display:flex;gap:0.6rem;">
                <button type="submit" class="btn-primary"
                        style="flex:1;justify-content:center;padding:10px;border-radius:10px;">
                    Pay Now
                </button>
                <button type="button" onclick="closePayment()"
                        style="flex:1;padding:10px;border-radius:10px;border:1px solid var(--border-dark);background:none;color:var(--text-secondary-dark);cursor:pointer;font-size:0.875rem;">
                    Cancel
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        const priorityColors = { 'High': '#f43f5e', 'Medium': '#eab308', 'Low': '#22c55e' };

        function selectPriority(priority) {
            ['High', 'Medium', 'Low'].forEach(function (p) {
                const btn = document.getElementById('pbtn_' + p);
                const radio = document.getElementById('priority_' + p);
                const color = priorityColors[p];
                if (p === priority) {
                    btn.style.border = '1px solid ' + color;
                    btn.style.background = color + '18';
                    btn.style.color = color;
                    radio.checked = true;
                } else {
                    btn.style.border = '1px solid var(--border-dark)';
                    btn.style.background = 'none';
                    btn.style.color = 'var(--text-secondary-dark)';
                }
            });
        }

        function openPayment(debtId, debtName, monthlyPayment) {
            document.getElementById('paymentDebtId').value = debtId;
            document.getElementById('paymentDebtName').textContent = 'Payment for: ' + debtName;
            document.getElementById('paymentAmount').value = monthlyPayment;
            document.getElementById('suggestedPayment').textContent = '₦' + Number(monthlyPayment).toLocaleString();
            const modal = document.getElementById('paymentModal');
            modal.style.display = 'flex';
            setTimeout(() => document.getElementById('paymentAmount').focus(), 100);
        }

        function closePayment() {
            document.getElementById('paymentModal').style.display = 'none';
        }

        document.getElementById('paymentModal').addEventListener('click', function (e) {
            if (e.target === this) closePayment();
        });
    </script>
}