@model FinTrack.Models.ViewModels.SettingsViewModel
@{
    ViewData["Title"] = "Settings";
}

<style>
    .settings-grid {
        display: grid;
        grid-template-columns: 220px 1fr;
        gap: 1.25rem;
        align-items: start;
    }

    .settings-nav {
        position: sticky;
        top: 76px;
    }

    .settings-nav-item {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        padding: 0.6rem 0.85rem;
        border-radius: 9px;
        font-size: 0.85rem;
        font-weight: 500;
        color: var(--text-secondary-dark);
        cursor: pointer;
        text-decoration: none;
        transition: all 0.15s;
        margin-bottom: 0.25rem;
    }

        .settings-nav-item:hover,
        .settings-nav-item.active {
            background: var(--bg-card2);
            color: var(--text-primary-dark);
        }

        .settings-nav-item.danger:hover {
            background: rgba(244,63,94,0.08);
            color: var(--accent);
        }

    .settings-section {
        display: none;
    }

        .settings-section.active {
            display: block;
        }

    @@media (max-width: 768px) {
        .settings-grid {
            grid-template-columns: 1fr;
        }

        .settings-nav {
            position: static;
            display: flex;
            flex-wrap: wrap;
            gap: 0.4rem;
            background: var(--bg-card);
            border: 1px solid var(--border-dark);
            border-radius: 12px;
            padding: 0.75rem;
        }

        .settings-nav-item {
            margin-bottom: 0;
            flex: 1;
            min-width: 120px;
            justify-content: center;
            font-size: 0.8rem;
        }
    }
</style>

<div class="page-header">
    <h1>Settings</h1>
    <p>Manage your account and preferences</p>
</div>

<div class="settings-grid">

    <!-- ── Sidebar Nav ── -->
    <div class="settings-nav card">
        <a class="settings-nav-item active" onclick="showSection('profile')" id="nav-profile">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2" />
                <circle cx="12" cy="7" r="4" />
            </svg>
            Profile
        </a>
        <a class="settings-nav-item" onclick="showSection('password')" id="nav-password">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                <path d="M7 11V7a5 5 0 0110 0v4" />
            </svg>
            Password
        </a>
        <a class="settings-nav-item danger" onclick="showSection('danger')" id="nav-danger">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="3 6 5 6 21 6" />
                <path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6" />
                <path d="M10 11v6M14 11v6" />
                <path d="M9 6V4a1 1 0 011-1h4a1 1 0 011 1v2" />
            </svg>
            Danger Zone
        </a>
    </div>

    <!-- ── Content Sections ── -->
    <div>

        <!-- Profile Section -->
        <div class="settings-section active card" id="section-profile">
            <h3 style="font-size:0.95rem;margin-bottom:0.35rem;">Profile Information</h3>
            <p style="font-size:0.82rem;color:var(--text-secondary-dark);margin-bottom:1.5rem;">
                Update your name and email address.
            </p>

            @if (TempData["ProfileSuccess"] != null)
            {
                <div style="background:rgba(34,197,94,0.08);border:1px solid rgba(34,197,94,0.2);border-radius:10px;padding:0.75rem 1rem;margin-bottom:1.25rem;color:#22c55e;font-size:0.875rem;">
                    ✓ @TempData["ProfileSuccess"]
                </div>
            }
            @if (TempData["ProfileError"] != null)
            {
                <div style="background:rgba(244,63,94,0.08);border:1px solid rgba(244,63,94,0.2);border-radius:10px;padding:0.75rem 1rem;margin-bottom:1.25rem;color:var(--accent);font-size:0.875rem;">
                    ✕ @TempData["ProfileError"]
                </div>
            }

            <form asp-action="UpdateProfile" asp-controller="Settings" method="post"
                  style="display:flex;flex-direction:column;gap:1rem;max-width:480px;">
                @Html.AntiForgeryToken()

                <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;">
                    <div>
                        <label class="input-label" asp-for="Profile.FirstName">First Name</label>
                        <input asp-for="Profile.FirstName" class="input-field"
                               placeholder="John" />
                        <span asp-validation-for="Profile.FirstName"
                              style="color:var(--accent);font-size:0.78rem;"></span>
                    </div>
                    <div>
                        <label class="input-label" asp-for="Profile.LastName">Last Name</label>
                        <input asp-for="Profile.LastName" class="input-field"
                               placeholder="Doe" />
                        <span asp-validation-for="Profile.LastName"
                              style="color:var(--accent);font-size:0.78rem;"></span>
                    </div>
                </div>

                <div>
                    <label class="input-label" asp-for="Profile.Email">Email Address</label>
                    <input asp-for="Profile.Email" class="input-field" type="email"
                           placeholder="john@example.com" />
                    <span asp-validation-for="Profile.Email"
                          style="color:var(--accent);font-size:0.78rem;"></span>
                </div>

                <div>
                    <button type="submit" class="btn-primary"
                            style="padding:0.6rem 1.5rem;border-radius:9px;">
                        Save Changes
                    </button>
                </div>
            </form>
        </div>

        <!-- Password Section -->
        <div class="settings-section card" id="section-password">
            <h3 style="font-size:0.95rem;margin-bottom:0.35rem;">Change Password</h3>
            <p style="font-size:0.82rem;color:var(--text-secondary-dark);margin-bottom:1.5rem;">
                Choose a strong password with at least 6 characters.
            </p>

            @if (TempData["PasswordSuccess"] != null)
            {
                <div style="background:rgba(34,197,94,0.08);border:1px solid rgba(34,197,94,0.2);border-radius:10px;padding:0.75rem 1rem;margin-bottom:1.25rem;color:#22c55e;font-size:0.875rem;">
                    ✓ @TempData["PasswordSuccess"]
                </div>
            }
            @if (TempData["PasswordError"] != null)
            {
                <div style="background:rgba(244,63,94,0.08);border:1px solid rgba(244,63,94,0.2);border-radius:10px;padding:0.75rem 1rem;margin-bottom:1.25rem;color:var(--accent);font-size:0.875rem;">
                    ✕ @TempData["PasswordError"]
                </div>
            }

            <form asp-action="ChangePassword" asp-controller="Settings" method="post"
                  style="display:flex;flex-direction:column;gap:1rem;max-width:480px;">
                @Html.AntiForgeryToken()

                <div>
                    <label class="input-label" asp-for="ChangePassword.CurrentPassword">Current Password</label>
                    <input asp-for="ChangePassword.CurrentPassword" class="input-field"
                           type="password" placeholder="••••••••" />
                    <span asp-validation-for="ChangePassword.CurrentPassword"
                          style="color:var(--accent);font-size:0.78rem;"></span>
                </div>

                <div>
                    <label class="input-label" asp-for="ChangePassword.NewPassword">New Password</label>
                    <input asp-for="ChangePassword.NewPassword" class="input-field"
                           type="password" placeholder="••••••••" />
                    <span asp-validation-for="ChangePassword.NewPassword"
                          style="color:var(--accent);font-size:0.78rem;"></span>
                </div>

                <div>
                    <label class="input-label" asp-for="ChangePassword.ConfirmPassword">Confirm New Password</label>
                    <input asp-for="ChangePassword.ConfirmPassword" class="input-field"
                           type="password" placeholder="••••••••" />
                    <span asp-validation-for="ChangePassword.ConfirmPassword"
                          style="color:var(--accent);font-size:0.78rem;"></span>
                </div>

                <!-- Password strength indicator -->
                <div id="strengthBar" style="display:none;">
                    <div style="font-size:0.75rem;color:var(--text-secondary-dark);margin-bottom:0.3rem;">
                        Password strength: <span id="strengthLabel" style="font-weight:600;"></span>
                    </div>
                    <div style="height:4px;background:var(--bg-card2);border-radius:99px;overflow:hidden;">
                        <div id="strengthFill" style="height:100%;width:0%;border-radius:99px;transition:all 0.3s;"></div>
                    </div>
                </div>

                <div>
                    <button type="submit" class="btn-primary"
                            style="padding:0.6rem 1.5rem;border-radius:9px;">
                        Change Password
                    </button>
                </div>
            </form>
        </div>

        <!-- Danger Zone Section -->
        <div class="settings-section card" id="section-danger"
             style="border:1px solid rgba(244,63,94,0.25);">
            <h3 style="font-size:0.95rem;margin-bottom:0.35rem;color:var(--accent);">Danger Zone</h3>
            <p style="font-size:0.82rem;color:var(--text-secondary-dark);margin-bottom:1.5rem;">
                Permanent actions that cannot be undone. Please proceed with caution.
            </p>

            <div style="background:rgba(244,63,94,0.05);border:1px solid rgba(244,63,94,0.15);border-radius:10px;padding:1.25rem;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;">
                <div>
                    <div style="font-size:0.875rem;font-weight:600;margin-bottom:0.2rem;">Delete Account</div>
                    <div style="font-size:0.8rem;color:var(--text-secondary-dark);">
                        Permanently delete your account and all associated data. This cannot be undone.
                    </div>
                </div>
                <button type="button" onclick="confirmDelete()"
                        style="padding:0.5rem 1.25rem;border-radius:9px;border:1px solid var(--accent);background:rgba(244,63,94,0.08);color:var(--accent);font-size:0.85rem;font-weight:600;cursor:pointer;white-space:nowrap;flex-shrink:0;">
                    Delete Account
                </button>
            </div>

            <!-- Hidden delete form -->
            <form asp-action="DeleteAccount" asp-controller="Settings" method="post"
                  id="deleteAccountForm" style="display:none;">
                @Html.AntiForgeryToken()
            </form>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        // ── Section navigation ──────────────────────────────
        function showSection(name) {
            // Hide all sections
            document.querySelectorAll('.settings-section').forEach(s => {
                s.classList.remove('active');
            });
            // Remove active from all nav items
            document.querySelectorAll('.settings-nav-item').forEach(n => {
                n.classList.remove('active');
            });
            // Show selected
            document.getElementById('section-' + name).classList.add('active');
            document.getElementById('nav-' + name).classList.add('active');
        }

        // ── Auto-show section if TempData present ──────────
        document.addEventListener('DOMContentLoaded', function () {
            @if (TempData["PasswordSuccess"] != null || TempData["PasswordError"] != null)
            {
                    <text>showSection('password');</text>
            }
            else if (TempData["ProfileSuccess"] != null || TempData["ProfileError"] != null)
            {
                    <text>showSection('profile');</text>
            }

            // Password strength meter
            const newPwdInput = document.querySelector('[name="ChangePassword.NewPassword"]');
            if (newPwdInput) {
                newPwdInput.addEventListener('input', function () {
                    const val = this.value;
                    const bar = document.getElementById('strengthBar');
                    const fill = document.getElementById('strengthFill');
                    const label = document.getElementById('strengthLabel');

                    if (val.length === 0) {
                        bar.style.display = 'none';
                        return;
                    }

                    bar.style.display = 'block';
                    let score = 0;
                    if (val.length >= 6) score++;
                    if (val.length >= 10) score++;
                    if (/[A-Z]/.test(val)) score++;
                    if (/[0-9]/.test(val)) score++;
                    if (/[^A-Za-z0-9]/.test(val)) score++;

                    const levels = [
                        { label: 'Very Weak', color: '#f43f5e', width: '20%' },
                        { label: 'Weak',      color: '#f97316', width: '40%' },
                        { label: 'Fair',      color: '#eab308', width: '60%' },
                        { label: 'Strong',    color: '#22c55e', width: '80%' },
                        { label: 'Very Strong', color: '#16a34a', width: '100%' }
                    ];

                    const level = levels[Math.min(score - 1, 4)] || levels[0];
                    fill.style.width = level.width;
                    fill.style.background = level.color;
                    label.textContent = level.label;
                    label.style.color = level.color;
                });
            }
        });

        // ── Delete account confirmation ─────────────────────
        function confirmDelete() {
            const confirmed = confirm(
                'Are you sure you want to delete your account?\n\n' +
                'This will permanently delete all your data including transactions, ' +
                'budgets, savings goals, investments, and debts.\n\n' +
                'This action CANNOT be undone.'
            );
            if (confirmed) {
                document.getElementById('deleteAccountForm').submit();
            }
        }
    </script>
}