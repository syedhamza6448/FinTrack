@model FinTrack.Models.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<style>
    .grid-4 {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1.25rem;
    }

    .grid-2 {
        display: grid;
        grid-template-columns: 1.4fr 1fr;
        gap: 1.25rem;
    }

    .grid-3 {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.25rem;
    }

    @@media (max-width: 1024px) {
        .grid-4 {
            grid-template-columns: repeat(2, 1fr);
        }

        .grid-2 {
            grid-template-columns: 1fr;
        }

        .grid-3 {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 640px) {
        .grid-4 {
            grid-template-columns: 1fr;
        }

        .grid-2 {
            grid-template-columns: 1fr;
        }

        .grid-3 {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="page-header">
    <h1>Dashboard</h1>
    <p>Welcome back, @Model.UserFirstName — here's your financial overview</p>
</div>

<!-- Stats -->
<div class="grid-4" style="margin-bottom:1.25rem;">
    <div class="card stat-card">
        <div class="stat-label">Total Balance</div>
        <div class="stat-value">₦@Model.TotalBalance.ToString("N0")</div>
        <div class="stat-change" style="color:@(Model.TotalBalance >= 0 ? "#22c55e" : "var(--accent)");">
            @(Model.TotalBalance >= 0 ? "▲ Positive balance" : "▼ Negative balance")
        </div>
    </div>
    <div class="card stat-card">
        <div class="stat-label">Monthly Spent</div>
        <div class="stat-value">₦@Model.MonthlySpending.ToString("N0")</div>
        <div class="stat-change" style="color:var(--text-secondary-dark);">This month</div>
    </div>
    <div class="card stat-card">
        <div class="stat-label">Total Savings</div>
        <div class="stat-value">₦@Model.TotalSavings.ToString("N0")</div>
        <div class="stat-change" style="color:#22c55e;">Across all goals</div>
    </div>
    <div class="card stat-card">
        <div class="stat-label">Monthly Budget</div>
        <div class="stat-value">₦@Model.TotalBudget.ToString("N0")</div>
        @{
            var budgetUsedPct = Model.TotalBudget > 0
            ? (int)Math.Min((Model.MonthlySpending / Model.TotalBudget) * 100, 100)
            : 0;
        }
        <div class="stat-change" style="color:@(budgetUsedPct >= 100 ? "var(--accent)" : budgetUsedPct >= 75 ? "#eab308" : "#22c55e");">
            @(100 - budgetUsedPct)% remaining
        </div>
    </div>
</div>

<!-- Row 2 -->
<div class="grid-2" style="margin-bottom:1.25rem;">

    <!-- Spending Chart -->
    <div class="card">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem;">
            <h3 style="font-size:0.95rem;">Spending Overview — Last 6 Months</h3>
        </div>
        <canvas id="spendingChart" height="160"></canvas>
    </div>

    <!-- Recent Transactions -->
    <div class="card">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.75rem;">
            <h3 style="font-size:0.95rem;">Recent Transactions</h3>
            <a asp-controller="Transactions" asp-action="Index"
               style="font-size:0.78rem;color:var(--accent);">View all</a>
        </div>

        @if (!Model.RecentTransactions.Any())
        {
            <p style="color:var(--text-secondary-dark);font-size:0.85rem;text-align:center;padding:2rem 0;">
                No transactions yet.
            </p>
        }
        else
        {
            @foreach (var tx in Model.RecentTransactions)
            {
                <div class="tx-row">
                    <div style="display:flex;align-items:center;gap:0.75rem;">
                        <div class="tx-icon"
                             style="background:@(tx.Type == "Income" ? "rgba(34,197,94,0.1)" : "rgba(244,63,94,0.1)");
                                            color:@(tx.Type == "Income" ? "#22c55e" : "var(--accent)");">
                            @if (tx.Type == "Income")
                            {
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                                    <line x1="12" y1="1" x2="12" y2="23" />
                                    <path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6" />
                                </svg>
                            }
                            else
                            {
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                                    <circle cx="9" cy="21" r="1" />
                                    <circle cx="20" cy="21" r="1" />
                                    <path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 001.95-1.57l1.65-8.42H6" />
                                </svg>
                            }
                        </div>
                        <div>
                            <div style="font-size:0.85rem;font-weight:500;">@tx.Description</div>
                            <div style="font-size:0.72rem;color:var(--text-secondary-dark);">
                                @tx.Category?.Name · @tx.Date.ToString("MMM dd, yyyy")
                            </div>
                        </div>
                    </div>
                    <span style="font-weight:600;font-size:0.875rem;color:@(tx.Type == "Income" ? "#22c55e" : "var(--accent)");">
                        @(tx.Type == "Income" ? "+" : "-")₦@tx.Amount.ToString("N0")
                    </span>
                </div>
            }
        }
    </div>
</div>

<!-- Row 3 -->
<div class="grid-3">

    <!-- Budget Status -->
    <div class="card">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem;">
            <h3 style="font-size:0.95rem;">Budget Status</h3>
            <a asp-controller="Budget" asp-action="Index"
               style="font-size:0.78rem;color:var(--accent);">Details</a>
        </div>
        <div style="display:flex;flex-direction:column;gap:0.875rem;">
            @if (!Model.Budgets.Any())
            {
                <p style="color:var(--text-secondary-dark);font-size:0.82rem;text-align:center;padding:1rem 0;">
                    No budgets set yet.
                </p>
            }
            else
            {
                @foreach (var budget in Model.Budgets)
                {
                    var spent = Model.RecentTransactions
                    .Where(t => t.CategoryId == budget.CategoryId && t.Type == "Expense")
                    .Sum(t => t.Amount);
                    var pct = budget.Amount > 0
                    ? (int)Math.Min((spent / budget.Amount) * 100, 100) : 0;
                    var barColor = pct >= 100 ? "var(--accent)"
                    : pct >= 75 ? "#eab308" : "#22c55e";

                    <div>
                        <div style="display:flex;justify-content:space-between;font-size:0.8rem;margin-bottom:0.35rem;">
                            <span>@budget.Category?.Name</span>
                            <span style="color:var(--text-secondary-dark);">
                                ₦@spent.ToString("N0") / ₦@budget.Amount.ToString("N0")
                            </span>
                        </div>
                        <div class="progress-bar-bg">
                            <div class="progress-bar-fill"
                                 style="width:@(pct)%;background:@barColor;"></div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>

    <!-- Savings Goals -->
    <div class="card">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem;">
            <h3 style="font-size:0.95rem;">Savings Goals</h3>
            <a asp-controller="Savings" asp-action="Index"
               style="font-size:0.78rem;color:var(--accent);">All goals</a>
        </div>
        <div style="display:flex;flex-direction:column;gap:0.875rem;">
            @if (!Model.SavingsGoals.Any())
            {
                <p style="color:var(--text-secondary-dark);font-size:0.82rem;text-align:center;padding:1rem 0;">
                    No savings goals yet.
                </p>
            }
            else
            {
                @foreach (var goal in Model.SavingsGoals)
                {
                    var pct = goal.TargetAmount > 0
                    ? (int)Math.Min((goal.SavedAmount / goal.TargetAmount) * 100, 100) : 0;
                    var color = pct >= 75 ? "#22c55e"
                    : pct >= 40 ? "#3b82f6" : "var(--accent)";

                    <div>
                        <div style="display:flex;justify-content:space-between;font-size:0.8rem;margin-bottom:0.35rem;">
                            <span>@goal.Name</span>
                            <span style="color:@color;">@pct%</span>
                        </div>
                        <div class="progress-bar-bg">
                            <div class="progress-bar-fill"
                                 style="width:@(pct)%;background:@color;"></div>
                        </div>
                        <div style="font-size:0.72rem;color:var(--text-secondary-dark);margin-top:0.2rem;">
                            ₦@goal.SavedAmount.ToString("N0") of ₦@goal.TargetAmount.ToString("N0")
                        </div>
                    </div>
                }
            }
        </div>
    </div>

    <!-- Expense Breakdown -->
    <div class="card">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem;">
            <h3 style="font-size:0.95rem;">Expense Breakdown</h3>
            <a asp-controller="Transactions" asp-action="Index"
               style="font-size:0.78rem;color:var(--accent);">Details</a>
        </div>
        @if (!Model.RecentTransactions.Any(t => t.Type == "Expense"))
        {
            <p style="color:var(--text-secondary-dark);font-size:0.82rem;text-align:center;padding:2rem 0;">
                No expenses yet.
            </p>
        }
        else
        {
            <canvas id="expenseChart" height="130"></canvas>
        }
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>
    <script>
        const isDark = () => !document.body.classList.contains('light');
        const gridColor = () => isDark() ? 'rgba(255,255,255,0.06)' : 'rgba(0,0,0,0.06)';
        const textColor = () => isDark() ? '#7c7c8a' : '#6b6b7b';

        // ── Spending Chart (real data from model) ────────────
        const spendingLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                    Model.MonthlyTrends.Select(t => t.MonthLabel)));
    const spendingIncome = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                Model.MonthlyTrends.Select(t => t.Income)));
    const spendingExpenses = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                Model.MonthlyTrends.Select(t => t.Expenses)));

    new Chart(document.getElementById('spendingChart').getContext('2d'), {
        type: 'bar',
        data: {
            labels: spendingLabels,
            datasets: [{
                label: 'Income',
                data: spendingIncome,
                backgroundColor: 'rgba(34,197,94,0.7)',
                borderRadius: 5,
                borderSkipped: false
            }, {
                label: 'Expenses',
                data: spendingExpenses,
                backgroundColor: 'rgba(244,63,94,0.7)',
                borderRadius: 5,
                borderSkipped: false
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: true,
            plugins: {
                legend: {
                    labels: {
                        color: textColor(),
                        font: { family: 'Outfit', size: 11 },
                        boxWidth: 10
                    }
                }
            },
            scales: {
                x: {
                    grid: { color: gridColor() },
                    ticks: { color: textColor(), font: { family: 'Outfit', size: 11 } }
                },
                y: {
                    grid: { color: gridColor() },
                    ticks: {
                        color: textColor(),
                        font: { family: 'Outfit', size: 11 },
                        callback: v => '₦' + (v / 1000).toFixed(0) + 'K'
                    }
                }
            }
        }
    });

        // ── Expense Doughnut (real data from recent transactions) ──
    @{
                var expenseGroups = Model.RecentTransactions
                        .Where(t => t.Type == "Expense" && t.Category != null)
                        .GroupBy(t => new { t.Category!.Name, t.Category.Color })
                        .Select(g => new
                        {
                                Name = g.Key.Name,
                                Color = g.Key.Color,
                                Total = g.Sum(t => t.Amount)
                        })
                        .OrderByDescending(g => g.Total)
                        .ToList();
        }

        @if (expenseGroups.Any())
        {
                <text>
                const expenseLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                                expenseGroups.Select(g => g.Name)));
        const expenseData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                        expenseGroups.Select(g => g.Total)));
        const expenseColors = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                        expenseGroups.Select(g => g.Color)));

        new Chart(document.getElementById('expenseChart').getContext('2d'), {
            type: 'doughnut',
            data: {
                labels: expenseLabels,
                datasets: [{
                    data: expenseData,
                    backgroundColor: expenseColors,
                    borderWidth: 0,
                    hoverOffset: 4
                }]
            },
            options: {
                cutout: '68%',
                responsive: true,
                animation: { animateRotate: true, animateScale: true, duration: 1000 },
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: {
                            color: textColor(),
                            font: { family: 'Outfit', size: 10 },
                            boxWidth: 8,
                            padding: 8
                        }
                    }
                }
            }
        });
        </text>
        }
    </script>
}