@model FinTrack.Models.ViewModels.BudgetViewModel
@{
    ViewData["Title"] = "Budget";
    var months = System.Globalization.CultureInfo.CurrentCulture
        .DateTimeFormat.MonthNames.Take(12)
        .Select((m, i) => new { Name = m, Value = i + 1 });
}

<div class="page-header">
    <h1>Budget</h1>
    <p>Set and track your monthly spending limits</p>
</div>

@if (TempData["Success"] != null)
{
    <div style="background:rgba(34,197,94,0.08);border:1px solid rgba(34,197,94,0.2);border-radius:10px;padding:0.75rem 1rem;margin-bottom:1.25rem;color:#22c55e;font-size:0.875rem;">
        ✓ @TempData["Success"]
    </div>
}
@if (TempData["Error"] != null)
{
    <div style="background:rgba(244,63,94,0.08);border:1px solid rgba(244,63,94,0.2);border-radius:10px;padding:0.75rem 1rem;margin-bottom:1.25rem;color:var(--accent);font-size:0.875rem;">
        ✕ @TempData["Error"]
    </div>
}

<!-- Month Selector -->
<form method="get" asp-action="Index" asp-controller="Budget"
      style="display:flex;gap:0.6rem;align-items:center;margin-bottom:1.25rem;flex-wrap:wrap;">
    <select name="month" class="input-field" style="width:auto;padding:0.35rem 0.75rem;font-size:0.82rem;">
        @foreach (var m in months)
        {
            <option value="@m.Value" selected="@(Model.SelectedMonth == m.Value)">@m.Name</option>
        }
    </select>
    <select name="year" class="input-field" style="width:auto;padding:0.35rem 0.75rem;font-size:0.82rem;">
        @for (int y = DateTime.Now.Year + 1; y >= DateTime.Now.Year - 2; y--)
        {
            <option value="@y" selected="@(Model.SelectedYear == y)">@y</option>
        }
    </select>
    <button type="submit" class="btn-primary"
            style="padding:0.35rem 1rem;font-size:0.82rem;border-radius:8px;">
        Go
    </button>
</form>

<!-- Summary Stats -->
<div class="grid-4" style="margin-bottom:1.25rem;">
    <div class="card stat-card">
        <div class="stat-label">Total Budgeted</div>
        <div class="stat-value">₦@Model.TotalBudgeted.ToString("N0")</div>
    </div>
    <div class="card stat-card">
        <div class="stat-label">Total Spent</div>
        <div class="stat-value" style="color:var(--accent);">₦@Model.TotalSpent.ToString("N0")</div>
    </div>
    <div class="card stat-card">
        <div class="stat-label">Remaining</div>
        <div class="stat-value" style="color:@(Model.Remaining >= 0 ? "#22c55e" : "var(--accent)");">
            ₦@Model.Remaining.ToString("N0")
        </div>
    </div>
    <div class="card stat-card">
        <div class="stat-label">Budgets Set</div>
        <div class="stat-value">@Model.Budgets.Count</div>
    </div>
</div>

<div style="display:grid;grid-template-columns:1fr 320px;gap:1.25rem;align-items:start;">

    <!-- ── Budget List ── -->
    <div class="card">
        <h3 style="font-size:0.95rem;margin-bottom:1.25rem;">
            Budget Status —
            @System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(Model.SelectedMonth)
            @Model.SelectedYear
        </h3>

        @if (!Model.Budgets.Any())
        {
            <div style="text-align:center;padding:3rem 1rem;color:var(--text-secondary-dark);">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" style="margin:0 auto 1rem;display:block;opacity:0.4;"><path d="M9 7H6a2 2 0 00-2 2v9a2 2 0 002 2h12a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1-4h-4a1 1 0 00-1 1v4h6V4a1 1 0 00-1-1z" /></svg>
                <p style="font-size:0.9rem;margin-bottom:0.25rem;">No budgets for this month</p>
                <p style="font-size:0.8rem;">Add a budget using the form on the right</p>
            </div>
        }
        else
        {
            <div style="display:flex;flex-direction:column;gap:1.25rem;">
                @foreach (var item in Model.Budgets.OrderByDescending(b => b.ProgressPercent))
                {
                    <div>
                        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.5rem;">
                            <div style="display:flex;align-items:center;gap:0.6rem;">
                                <span style="width:10px;height:10px;border-radius:50%;background:@item.Budget.Category?.Color;flex-shrink:0;"></span>
                                <span style="font-size:0.875rem;font-weight:500;">@item.Budget.Category?.Name</span>
                                <span style="font-size:0.72rem;background:var(--bg-card2);border:1px solid var(--border-dark);border-radius:99px;padding:0.1rem 0.5rem;color:var(--text-secondary-dark);">
                                    @item.Budget.Period
                                </span>
                            </div>
                            <div style="display:flex;align-items:center;gap:0.75rem;">
                                <span style="font-size:0.82rem;color:var(--text-secondary-dark);">
                                    ₦@item.Spent.ToString("N0") / ₦@item.Budget.Amount.ToString("N0")
                                </span>
                                <span style="font-size:0.78rem;font-weight:600;color:@item.StatusColor;">
                                    @item.ProgressPercent%
                                </span>
                                <form asp-action="Delete" asp-controller="Budget" method="post" style="display:inline;margin:0;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.Budget.Id" />
                                    <button type="submit"
                                            onclick="return confirm('Delete this budget?')"
                                            style="background:none;border:none;cursor:pointer;color:var(--text-secondary-dark);padding:0.2rem;border-radius:5px;transition:color 0.15s;"
                                            onmouseover="this.style.color='var(--accent)'"
                                            onmouseout="this.style.color='var(--text-secondary-dark)'"
                                            title="Delete">
                                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6" /><path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6" /><path d="M10 11v6M14 11v6" /><path d="M9 6V4a1 1 0 011-1h4a1 1 0 011 1v2" /></svg>
                                    </button>
                                </form>
                            </div>
                        </div>

                        <!-- Progress Bar -->
                        <div style="height:8px;background:var(--bg-card2);border-radius:99px;overflow:hidden;">
                            <div style="height:100%;width:@(item.ProgressPercent)%;background:@item.StatusColor;border-radius:99px;transition:width 0.6s ease;"></div>
                        </div>

                        @if (item.ProgressPercent >= 100)
                        {
                            <div style="font-size:0.75rem;color:#f43f5e;margin-top:0.3rem;">
                                ⚠ Over budget by ₦@((item.Spent - item.Budget.Amount).ToString("N0"))
                            </div>
                        }
                        else if (item.ProgressPercent >= 75)
                        {
                            <div style="font-size:0.75rem;color:#eab308;margin-top:0.3rem;">
                                ⚡ ₦@item.Remaining.ToString("N0") remaining — approaching limit
                            </div>
                        }
                        else
                        {
                            <div style="font-size:0.75rem;color:#22c55e;margin-top:0.3rem;">
                                ✓ ₦@item.Remaining.ToString("N0") remaining
                            </div>
                        }
                    </div>
                }
            </div>
        }
    </div>

    <!-- ── Add Budget Form ── -->
    <div class="card" style="position:sticky;top:76px;">
        <h3 style="font-size:0.95rem;margin-bottom:1.25rem;">Add Budget</h3>

        <form asp-action="Create" asp-controller="Budget" method="post"
              style="display:flex;flex-direction:column;gap:1rem;">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly"
                 style="color:var(--accent);font-size:0.82rem;padding:0.5rem;background:rgba(244,63,94,0.08);border-radius:8px;">
            </div>

            <div>
                <label class="input-label" asp-for="NewBudget.CategoryId">Category</label>
                <select asp-for="NewBudget.CategoryId" class="input-field">
                    <option value="">Select expense category...</option>
                    @foreach (var cat in Model.Categories)
                    {
                        <option value="@cat.Id">@cat.Name</option>
                    }
                </select>
                <span asp-validation-for="NewBudget.CategoryId" style="color:var(--accent);font-size:0.78rem;"></span>
            </div>

            <div>
                <label class="input-label" asp-for="NewBudget.Amount">Budget Amount (₦)</label>
                <input asp-for="NewBudget.Amount" class="input-field" type="number"
                       placeholder="0.00" step="0.01" min="1" />
                <span asp-validation-for="NewBudget.Amount" style="color:var(--accent);font-size:0.78rem;"></span>
            </div>

            <div>
                <label class="input-label" asp-for="NewBudget.Period">Period</label>
                <select asp-for="NewBudget.Period" class="input-field">
                    <option value="Monthly">Monthly</option>
                    <option value="Weekly">Weekly</option>
                    <option value="Annual">Annual</option>
                </select>
            </div>

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.6rem;">
                <div>
                    <label class="input-label" asp-for="NewBudget.Month">Month</label>
                    <select asp-for="NewBudget.Month" class="input-field">
                        @foreach (var m in months)
                        {
                            <option value="@m.Value" selected="@(Model.SelectedMonth == m.Value)">@m.Name</option>
                        }
                    </select>
                </div>
                <div>
                    <label class="input-label" asp-for="NewBudget.Year">Year</label>
                    <select asp-for="NewBudget.Year" class="input-field">
                        @for (int y = DateTime.Now.Year + 1; y >= DateTime.Now.Year - 2; y--)
                        {
                            <option value="@y" selected="@(Model.SelectedYear == y)">@y</option>
                        }
                    </select>
                </div>
            </div>

            <button type="submit" class="btn-primary"
                    style="width:100%;justify-content:center;padding:10px;border-radius:10px;">
                + Add Budget
            </button>
        </form>
    </div>

</div>