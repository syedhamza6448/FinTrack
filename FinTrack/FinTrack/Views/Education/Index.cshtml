@{
    ViewData["Title"] = "Education";
}

<style>
    .edu-stats {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1.25rem;
        margin-bottom: 1.25rem;
    }

    .edu-tabs {
        display: flex;
        gap: 0.4rem;
        flex-wrap: wrap;
        margin-bottom: 1.25rem;
        background: var(--bg-card);
        border: 1px solid var(--border-dark);
        border-radius: 12px;
        padding: 0.5rem;
    }

    .edu-tab {
        padding: 0.5rem 1rem;
        border-radius: 8px;
        font-size: 0.83rem;
        font-weight: 600;
        cursor: pointer;
        border: none;
        background: none;
        color: var(--text-secondary-dark);
        transition: all 0.15s;
    }

        .edu-tab.active {
            background: var(--accent);
            color: white;
        }

        .edu-tab:hover:not(.active) {
            background: var(--bg-card2);
            color: var(--text-primary-dark);
        }

    .edu-panel {
        display: none;
    }

        .edu-panel.active {
            display: block;
        }

    /* Tips grid */
    .tips-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.25rem;
        margin-bottom: 1.25rem;
    }

    .tip-card {
        background: var(--bg-card);
        border: 1px solid var(--border-dark);
        border-radius: 14px;
        padding: 1.25rem;
        transition: all 0.15s;
    }

        .tip-card:hover {
            border-color: var(--accent);
            transform: translateY(-2px);
        }

    /* Calculator */
    .calc-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.25rem;
    }

    .calc-card {
        background: var(--bg-card);
        border: 1px solid var(--border-dark);
        border-radius: 14px;
        padding: 1.25rem;
    }

    .calc-input-group {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        margin-bottom: 1rem;
    }

    .calc-result {
        background: var(--bg-card2);
        border: 1px solid var(--border-dark);
        border-radius: 10px;
        padding: 1rem;
        text-align: center;
        display: none;
    }

        .calc-result.show {
            display: block;
        }

    .calc-result-value {
        font-size: 1.5rem;
        font-weight: 700;
        color: #22c55e;
        margin-bottom: 0.25rem;
    }

    .calc-result-label {
        font-size: 0.78rem;
        color: var(--text-secondary-dark);
    }

    /* Articles */
    .articles-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1.25rem;
    }

    .article-card {
        background: var(--bg-card);
        border: 1px solid var(--border-dark);
        border-radius: 14px;
        padding: 1.25rem;
        cursor: pointer;
        transition: all 0.15s;
    }

        .article-card:hover {
            border-color: var(--accent);
            transform: translateY(-2px);
        }

    .article-body {
        display: none;
        margin-top: 1rem;
        padding-top: 1rem;
        border-top: 1px solid var(--border-dark);
        font-size: 0.83rem;
        color: var(--text-secondary-dark);
        line-height: 1.7;
    }

        .article-body.open {
            display: block;
        }

    @@media (max-width: 1024px) {
        .tips-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .calc-grid {
            grid-template-columns: 1fr;
        }

        .articles-grid {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 640px) {
        .edu-stats {
            grid-template-columns: repeat(2, 1fr);
        }

        .tips-grid {
            grid-template-columns: 1fr;
        }

        .edu-tab {
            font-size: 0.78rem;
            padding: 0.4rem 0.75rem;
        }
    }
</style>

<div class="page-header">
    <h1>Financial Education</h1>
    <p>Learn, calculate and improve your financial health</p>
</div>

<!-- Stats -->
<div class="edu-stats">
    <div class="card stat-card">
        <div class="stat-label">Tips & Guides</div>
        <div class="stat-value" style="color:#3b82f6;">12</div>
    </div>
    <div class="card stat-card">
        <div class="stat-label">Articles</div>
        <div class="stat-value" style="color:#8b5cf6;">6</div>
    </div>
    <div class="card stat-card">
        <div class="stat-label">Calculators</div>
        <div class="stat-value" style="color:#22c55e;">3</div>
    </div>
    <div class="card stat-card">
        <div class="stat-label">Topics Covered</div>
        <div class="stat-value" style="color:#eab308;">5</div>
    </div>
</div>

<!-- Tabs -->
<div class="edu-tabs">
    <button class="edu-tab active" onclick="switchTab('tips')">💡 Tips & Guides</button>
    <button class="edu-tab" onclick="switchTab('calculators')">🧮 Calculators</button>
    <button class="edu-tab" onclick="switchTab('articles')">📖 Articles</button>
</div>

<!-- ── TIPS PANEL ── -->
<div class="edu-panel active" id="panel-tips">

    <!-- Budgeting -->
    <div style="margin-bottom:1.5rem;">
        <h3 style="font-size:0.85rem;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;color:var(--text-secondary-dark);margin-bottom:0.75rem;">
            💰 Budgeting
        </h3>
        <div class="tips-grid">
            @{
                var budgetingTips = new[]
                {
                        ("50/30/20 Rule", "#3b82f6", "rgba(59,130,246,0.1)",
                        "Allocate 50% of income to needs, 30% to wants, and 20% to savings and debt repayment. This simple framework helps maintain financial balance.",
                        "M9 7H6a2 2 0 00-2 2v9a2 2 0 002 2h12a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1-4h-4a1 1 0 00-1 1v4h6V4a1 1 0 00-1-1z"),
                        ("Track Every Naira", "#f97316", "rgba(249,115,22,0.1)",
                        "Record every expense no matter how small. Small daily purchases like coffee or snacks can add up to thousands per month without you noticing.",
                        "M7 16V4m0 0L3 8m4-4l4 4M17 8v12m0 0l4-4m-4 4l-4-4"),
                        ("Zero-Based Budgeting", "#8b5cf6", "rgba(139,92,246,0.1)",
                        "Give every naira a job. Your income minus all allocated expenses should equal zero. This ensures every naira is intentionally assigned to a purpose.",
                        "M12 1v22M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"),
                        };
            }
            @foreach (var (title, color, bg, desc, path) in budgetingTips)
            {
                <div class="tip-card" style="border-top:3px solid @color;">
                    <div style="display:flex;align-items:center;gap:0.6rem;margin-bottom:0.75rem;">
                        <div style="width:36px;height:36px;border-radius:9px;background:@bg;color:@color;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="@path" /></svg>
                        </div>
                        <span style="font-weight:600;font-size:0.875rem;">@title</span>
                    </div>
                    <p style="font-size:0.82rem;color:var(--text-secondary-dark);line-height:1.6;">@desc</p>
                </div>
            }
        </div>
    </div>

    <!-- Saving -->
    <div style="margin-bottom:1.5rem;">
        <h3 style="font-size:0.85rem;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;color:var(--text-secondary-dark);margin-bottom:0.75rem;">
            🏦 Saving
        </h3>
        <div class="tips-grid">
            @{
                var savingTips = new[]
                {
                        ("Pay Yourself First", "#22c55e", "rgba(34,197,94,0.1)",
                        "Transfer a fixed amount to savings immediately when you receive income, before paying any bills. Automate this so it becomes effortless.",
                        "M19 5c-1.5 0-2.8 1.4-3 2-3.5 1.5-11 2.2-11 10 0 3.9 3.1 7 7 7h3"),
                        ("Emergency Fund First", "#eab308", "rgba(234,179,8,0.1)",
                        "Before investing, build an emergency fund covering 3–6 months of expenses. This protects you from needing to take on debt when unexpected costs arise.",
                        "M12 22a10 10 0 100-20 10 10 0 000 20zM12 8v4M12 16h.01"),
                        ("Automate Your Savings", "#14b8a6", "rgba(20,184,166,0.1)",
                        "Set up automatic transfers on payday. When savings happen automatically, you adjust your lifestyle to what remains rather than trying to save what is left over.",
                        "M13 2L3 14h9l-1 8 10-12h-9l1-8z"),
                        };
            }
            @foreach (var (title, color, bg, desc, path) in savingTips)
            {
                <div class="tip-card" style="border-top:3px solid @color;">
                    <div style="display:flex;align-items:center;gap:0.6rem;margin-bottom:0.75rem;">
                        <div style="width:36px;height:36px;border-radius:9px;background:@bg;color:@color;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="@path" /></svg>
                        </div>
                        <span style="font-weight:600;font-size:0.875rem;">@title</span>
                    </div>
                    <p style="font-size:0.82rem;color:var(--text-secondary-dark);line-height:1.6;">@desc</p>
                </div>
            }
        </div>
    </div>

    <!-- Debt -->
    <div style="margin-bottom:1.5rem;">
        <h3 style="font-size:0.85rem;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;color:var(--text-secondary-dark);margin-bottom:0.75rem;">
            💳 Debt Management
        </h3>
        <div class="tips-grid">
            @{
                var debtTips = new[]
                {
                        ("Avalanche Method", "#f43f5e", "rgba(244,63,94,0.1)",
                        "Pay minimum on all debts, then put extra money toward the highest interest rate debt first. This saves the most money in interest over time.",
                        "M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"),
                        ("Snowball Method", "#ec4899", "rgba(236,72,153,0.1)",
                        "Pay off the smallest debt first regardless of interest rate. Each paid-off debt gives you a psychological win and frees up cash for the next debt.",
                        "M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"),
                        ("Avoid Minimum Payments", "#f97316", "rgba(249,115,22,0.1)",
                        "Paying only the minimum on credit cards can take decades to clear the balance. Always pay more than the minimum to reduce the principal faster.",
                        "M1 4h22v4H1zM1 10h23M1 10v10h22V10"),
                        };
            }
            @foreach (var (title, color, bg, desc, path) in debtTips)
            {
                <div class="tip-card" style="border-top:3px solid @color;">
                    <div style="display:flex;align-items:center;gap:0.6rem;margin-bottom:0.75rem;">
                        <div style="width:36px;height:36px;border-radius:9px;background:@bg;color:@color;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="@path" /></svg>
                        </div>
                        <span style="font-weight:600;font-size:0.875rem;">@title</span>
                    </div>
                    <p style="font-size:0.82rem;color:var(--text-secondary-dark);line-height:1.6;">@desc</p>
                </div>
            }
        </div>
    </div>

    <!-- Investing -->
    <div>
        <h3 style="font-size:0.85rem;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;color:var(--text-secondary-dark);margin-bottom:0.75rem;">
            📈 Investing
        </h3>
        <div class="tips-grid">
            @{
                var investingTips = new[]
                {
                        ("Start Early", "#3b82f6", "rgba(59,130,246,0.1)",
                        "The power of compound interest means that starting 10 years earlier can double your final wealth. Even small amounts invested consistently create significant wealth over time.",
                        "M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"),
                        ("Diversify Your Portfolio", "#8b5cf6", "rgba(139,92,246,0.1)",
                        "Don't put all your eggs in one basket. Spread investments across different asset types (stocks, bonds, real estate) to reduce risk while maintaining growth potential.",
                        "M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"),
                        ("Invest Consistently", "#22c55e", "rgba(34,197,94,0.1)",
                        "Regular investing through market ups and downs (dollar-cost averaging) removes the pressure of timing the market and produces better results for most investors.",
                        "M23 6l-9.5 9.5-5-5L1 18"),
                        };
            }
            @foreach (var (title, color, bg, desc, path) in investingTips)
            {
                <div class="tip-card" style="border-top:3px solid @color;">
                    <div style="display:flex;align-items:center;gap:0.6rem;margin-bottom:0.75rem;">
                        <div style="width:36px;height:36px;border-radius:9px;background:@bg;color:@color;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="@path" /></svg>
                        </div>
                        <span style="font-weight:600;font-size:0.875rem;">@title</span>
                    </div>
                    <p style="font-size:0.82rem;color:var(--text-secondary-dark);line-height:1.6;">@desc</p>
                </div>
            }
        </div>
    </div>
</div>

<!-- ── CALCULATORS PANEL ── -->
<div class="edu-panel" id="panel-calculators">
    <div class="calc-grid">

        <!-- Debt Payoff Calculator -->
        <div class="calc-card">
            <div style="display:flex;align-items:center;gap:0.6rem;margin-bottom:1.25rem;">
                <div style="width:38px;height:38px;border-radius:10px;background:rgba(244,63,94,0.1);color:var(--accent);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2" /><line x1="1" y1="10" x2="23" y2="10" /></svg>
                </div>
                <div>
                    <div style="font-weight:700;font-size:0.9rem;">Debt Payoff Calculator</div>
                    <div style="font-size:0.75rem;color:var(--text-secondary-dark);">How long to pay off your debt?</div>
                </div>
            </div>

            <div class="calc-input-group">
                <div>
                    <label class="input-label">Total Debt Amount (₦)</label>
                    <input type="number" id="debt-amount" class="input-field"
                           placeholder="e.g. 500000" min="0" />
                </div>
                <div>
                    <label class="input-label">Annual Interest Rate (%)</label>
                    <input type="number" id="debt-rate" class="input-field"
                           placeholder="e.g. 18" min="0" max="100" step="0.1" />
                </div>
                <div>
                    <label class="input-label">Monthly Payment (₦)</label>
                    <input type="number" id="debt-payment" class="input-field"
                           placeholder="e.g. 25000" min="0" />
                </div>
            </div>

            <button onclick="calcDebt()" class="btn-primary"
                    style="width:100%;justify-content:center;padding:10px;border-radius:10px;margin-bottom:1rem;">
                Calculate
            </button>

            <div class="calc-result" id="debt-result">
                <div class="calc-result-value" id="debt-months"></div>
                <div class="calc-result-label">months to pay off</div>
                <div style="margin-top:0.75rem;display:grid;grid-template-columns:1fr 1fr;gap:0.5rem;">
                    <div style="background:var(--bg-card);border-radius:8px;padding:0.5rem;">
                        <div style="font-size:0.68rem;color:var(--text-secondary-dark);text-transform:uppercase;">Total Paid</div>
                        <div style="font-size:0.85rem;font-weight:600;" id="debt-total"></div>
                    </div>
                    <div style="background:var(--bg-card);border-radius:8px;padding:0.5rem;">
                        <div style="font-size:0.68rem;color:var(--text-secondary-dark);text-transform:uppercase;">Total Interest</div>
                        <div style="font-size:0.85rem;font-weight:600;color:var(--accent);" id="debt-interest"></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Savings Rate Calculator -->
        <div class="calc-card">
            <div style="display:flex;align-items:center;gap:0.6rem;margin-bottom:1.25rem;">
                <div style="width:38px;height:38px;border-radius:10px;background:rgba(34,197,94,0.1);color:#22c55e;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M19 5c-1.5 0-2.8 1.4-3 2-3.5 1.5-11 2.2-11 10 0 3.9 3.1 7 7 7h3" /><path d="M21 12c0 1-.5 2-2 2s-2-1-2-2 .5-2 2-2 2 1 2 2z" /></svg>
                </div>
                <div>
                    <div style="font-weight:700;font-size:0.9rem;">Savings Rate Calculator</div>
                    <div style="font-size:0.75rem;color:var(--text-secondary-dark);">How much of income are you saving?</div>
                </div>
            </div>

            <div class="calc-input-group">
                <div>
                    <label class="input-label">Monthly Income (₦)</label>
                    <input type="number" id="save-income" class="input-field"
                           placeholder="e.g. 200000" min="0" />
                </div>
                <div>
                    <label class="input-label">Monthly Savings (₦)</label>
                    <input type="number" id="save-amount" class="input-field"
                           placeholder="e.g. 40000" min="0" />
                </div>
                <div>
                    <label class="input-label">Years to Save</label>
                    <input type="number" id="save-years" class="input-field"
                           placeholder="e.g. 5" min="1" max="50" />
                </div>
            </div>

            <button onclick="calcSavings()" class="btn-primary"
                    style="width:100%;justify-content:center;padding:10px;border-radius:10px;margin-bottom:1rem;background:#22c55e;border-color:#22c55e;">
                Calculate
            </button>

            <div class="calc-result" id="save-result">
                <div class="calc-result-value" id="save-rate"></div>
                <div class="calc-result-label">savings rate</div>
                <div style="margin-top:0.75rem;display:grid;grid-template-columns:1fr 1fr;gap:0.5rem;">
                    <div style="background:var(--bg-card);border-radius:8px;padding:0.5rem;">
                        <div style="font-size:0.68rem;color:var(--text-secondary-dark);text-transform:uppercase;">Total Saved</div>
                        <div style="font-size:0.85rem;font-weight:600;color:#22c55e;" id="save-total"></div>
                    </div>
                    <div style="background:var(--bg-card);border-radius:8px;padding:0.5rem;">
                        <div style="font-size:0.68rem;color:var(--text-secondary-dark);text-transform:uppercase;">Rating</div>
                        <div style="font-size:0.85rem;font-weight:600;" id="save-rating"></div>
                    </div>
                </div>
                <!-- Progress bar -->
                <div style="margin-top:0.75rem;">
                    <div style="height:8px;background:var(--bg-card);border-radius:99px;overflow:hidden;">
                        <div id="save-bar" style="height:100%;width:0%;background:#22c55e;border-radius:99px;transition:width 0.6s ease;"></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Investment Growth Simulator -->
        <div class="calc-card">
            <div style="display:flex;align-items:center;gap:0.6rem;margin-bottom:1.25rem;">
                <div style="width:38px;height:38px;border-radius:10px;background:rgba(59,130,246,0.1);color:#3b82f6;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" /></svg>
                </div>
                <div>
                    <div style="font-weight:700;font-size:0.9rem;">Investment Simulator</div>
                    <div style="font-size:0.75rem;color:var(--text-secondary-dark);">Compound growth calculator</div>
                </div>
            </div>

            <div class="calc-input-group">
                <div>
                    <label class="input-label">Initial Investment (₦)</label>
                    <input type="number" id="inv-principal" class="input-field"
                           placeholder="e.g. 100000" min="0" />
                </div>
                <div>
                    <label class="input-label">Monthly Contribution (₦)</label>
                    <input type="number" id="inv-monthly" class="input-field"
                           placeholder="e.g. 10000" min="0" />
                </div>
                <div>
                    <label class="input-label">Annual Return Rate (%)</label>
                    <input type="number" id="inv-rate" class="input-field"
                           placeholder="e.g. 12" min="0" max="100" step="0.1" />
                </div>
                <div>
                    <label class="input-label">Investment Period (Years)</label>
                    <input type="number" id="inv-years" class="input-field"
                           placeholder="e.g. 10" min="1" max="50" />
                </div>
            </div>

            <button onclick="calcInvestment()" class="btn-primary"
                    style="width:100%;justify-content:center;padding:10px;border-radius:10px;margin-bottom:1rem;background:#3b82f6;border-color:#3b82f6;">
                Simulate
            </button>

            <div class="calc-result" id="inv-result">
                <div class="calc-result-value" id="inv-final"></div>
                <div class="calc-result-label">final portfolio value</div>
                <div style="margin-top:0.75rem;display:grid;grid-template-columns:1fr 1fr;gap:0.5rem;">
                    <div style="background:var(--bg-card);border-radius:8px;padding:0.5rem;">
                        <div style="font-size:0.68rem;color:var(--text-secondary-dark);text-transform:uppercase;">Total Invested</div>
                        <div style="font-size:0.85rem;font-weight:600;" id="inv-invested"></div>
                    </div>
                    <div style="background:var(--bg-card);border-radius:8px;padding:0.5rem;">
                        <div style="font-size:0.68rem;color:var(--text-secondary-dark);text-transform:uppercase;">Total Growth</div>
                        <div style="font-size:0.85rem;font-weight:600;color:#22c55e;" id="inv-growth"></div>
                    </div>
                </div>
                <div style="margin-top:0.5rem;font-size:0.75rem;color:var(--text-secondary-dark);" id="inv-multiplier"></div>
            </div>
        </div>

    </div>
</div>

<!-- ── ARTICLES PANEL ── -->
<div class="edu-panel" id="panel-articles">
    <div class="articles-grid">
        @{
            var articles = new[]
            {
                (
                "Understanding the 50/30/20 Budget Rule",
                "Budgeting", "#3b82f6", "rgba(59,130,246,0.1)",
