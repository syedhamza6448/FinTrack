        @foreach (var (title, category, color, bg, readTime, paragraphs) in articles)
        {
            var articleId = title.Replace(" ", "").Replace("?", "").Replace(":", "").Replace("/", "");
            <div class="article-card" onclick="toggleArticle('@articleId')">
                <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:1rem;">
                    <div style="flex:1;">
                        <span style="font-size:0.7rem;font-weight:700;padding:0.15rem 0.5rem;border-radius:99px;background:@bg;color:@color;text-transform:uppercase;letter-spacing:0.05em;">
                            @category
                        </span>
                        <h3 style="font-size:0.9rem;font-weight:700;margin:0.5rem 0 0.25rem;">@title</h3>
                        <span style="font-size:0.75rem;color:var(--text-secondary-dark);">@readTime</span>
                    </div>
                    <svg id="arrow-@articleId" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                         style="flex-shrink:0;margin-top:0.25rem;transition:transform 0.2s;color:var(--text-secondary-dark);">
                        <polyline points="6 9 12 15 18 9" />
                    </svg>
                </div>

                <div class="article-body" id="article-@articleId">
                    @foreach (var para in paragraphs)
                    {
                        <p style="margin-bottom:0.75rem;">@para</p>
                    }
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        // ── Tab switching ──────────────────────────────────
        function switchTab(name) {
            document.querySelectorAll('.edu-tab').forEach(t => t.classList.remove('active'));
            document.querySelectorAll('.edu-panel').forEach(p => p.classList.remove('active'));
            document.getElementById('panel-' + name).classList.add('active');
            event.target.classList.add('active');
        }

        // ── Article toggle ─────────────────────────────────
        function toggleArticle(id) {
            const body = document.getElementById('article-' + id);
            const arrow = document.getElementById('arrow-' + id);
            body.classList.toggle('open');
            arrow.style.transform = body.classList.contains('open') ? 'rotate(180deg)' : 'rotate(0deg)';
        }

        // ── Debt Payoff Calculator ─────────────────────────
        function calcDebt() {
            const balance = parseFloat(document.getElementById('debt-amount').value);
            const annualRate = parseFloat(document.getElementById('debt-rate').value);
            const payment = parseFloat(document.getElementById('debt-payment').value);

            if (!balance || !payment || isNaN(annualRate)) {
                alert('Please fill in all fields.');
                return;
            }

            const monthlyRate = annualRate / 100 / 12;
            let remaining = balance;
            let months = 0;
            let totalPaid = 0;

            if (monthlyRate === 0) {
                months = Math.ceil(balance / payment);
                totalPaid = payment * months;
            } else {
                if (payment <= remaining * monthlyRate) {
                    alert('Monthly payment is too low to cover interest. Please increase it.');
                    return;
                }
                while (remaining > 0 && months < 1200) {
                    const interest = remaining * monthlyRate;
                    remaining = remaining + interest - payment;
                    totalPaid += payment;
                    months++;
                    if (remaining < 0) {
                        totalPaid += remaining;
                        remaining = 0;
                    }
                }
            }

            const totalInterest = totalPaid - balance;
            const years = Math.floor(months / 12);
            const remMonths = months % 12;
            let timeStr = years > 0 ? years + 'y ' : '';
            timeStr += remMonths + 'm';

            document.getElementById('debt-months').textContent = timeStr;
            document.getElementById('debt-total').textContent = '₦' + totalPaid.toLocaleString('en', { maximumFractionDigits: 0 });
            document.getElementById('debt-interest').textContent = '₦' + totalInterest.toLocaleString('en', { maximumFractionDigits: 0 });

            const result = document.getElementById('debt-result');
            result.classList.add('show');
        }

        // ── Savings Rate Calculator ────────────────────────
        function calcSavings() {
            const income = parseFloat(document.getElementById('save-income').value);
            const savings = parseFloat(document.getElementById('save-amount').value);
            const years = parseFloat(document.getElementById('save-years').value);

            if (!income || !savings || !years) {
                alert('Please fill in all fields.');
                return;
            }

            const rate = (savings / income) * 100;
            const total = savings * 12 * years;

            let rating, ratingColor;
            if (rate >= 20) { rating = '🌟 Excellent'; ratingColor = '#22c55e'; }
            else if (rate >= 15) { rating = '✅ Good'; ratingColor = '#22c55e'; }
            else if (rate >= 10) { rating = '⚡ Fair'; ratingColor = '#eab308'; }
            else if (rate >= 5) { rating = '⚠ Low'; ratingColor = '#f97316'; }
            else { rating = '❌ Critical'; ratingColor = '#f43f5e'; }

            document.getElementById('save-rate').textContent = rate.toFixed(1) + '%';
            document.getElementById('save-total').textContent = '₦' + total.toLocaleString('en', { maximumFractionDigits: 0 });
            document.getElementById('save-rating').textContent = rating;
            document.getElementById('save-rating').style.color = ratingColor;
            document.getElementById('save-bar').style.width = Math.min(rate * 4, 100) + '%';

            document.getElementById('save-result').classList.add('show');
        }

        // ── Investment Growth Simulator ────────────────────
        function calcInvestment() {
            const principal = parseFloat(document.getElementById('inv-principal').value) || 0;
            const monthly = parseFloat(document.getElementById('inv-monthly').value) || 0;
            const annualRate = parseFloat(document.getElementById('inv-rate').value);
            const years = parseFloat(document.getElementById('inv-years').value);

            if ((!principal && !monthly) || !annualRate || !years) {
                alert('Please fill in all required fields.');
                return;
            }

            const monthlyRate = annualRate / 100 / 12;
            const months = years * 12;

            // Future value of lump sum
            const fvPrincipal = principal * Math.pow(1 + monthlyRate, months);

            // Future value of monthly contributions
            const fvMonthly = monthly * ((Math.pow(1 + monthlyRate, months) - 1) / monthlyRate);

            const finalValue = fvPrincipal + fvMonthly;
            const totalInvested = principal + (monthly * months);
            const totalGrowth = finalValue - totalInvested;
            const multiplier = (finalValue / totalInvested).toFixed(2);

            document.getElementById('inv-final').textContent = '₦' + finalValue.toLocaleString('en', { maximumFractionDigits: 0 });
            document.getElementById('inv-invested').textContent = '₦' + totalInvested.toLocaleString('en', { maximumFractionDigits: 0 });
            document.getElementById('inv-growth').textContent = '₦' + totalGrowth.toLocaleString('en', { maximumFractionDigits: 0 });
            document.getElementById('inv-multiplier').textContent = '💡 Your money grows ' + multiplier + 'x over ' + years + ' years';

            document.getElementById('inv-result').classList.add('show');
        }
    </script>
}