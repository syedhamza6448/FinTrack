@model FinTrack.Models.ViewModels.LoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "Login";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login — FinTrack</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="~/css/style.css" />
    <style>
        .auth-bg {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem;
            background: var(--bg-dark);
            position: relative;
            overflow: hidden;
        }

        body.light .auth-bg {
            background: var(--bg-light);
        }

        .auth-glow {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%,-50%);
            width: 600px;
            height: 600px;
            background: radial-gradient(circle, rgba(244,63,94,0.07) 0%, transparent 70%);
            pointer-events: none;
        }

        .auth-card {
            width: 100%;
            max-width: 420px;
            background: var(--bg-card);
            border: 1px solid var(--border-dark);
            border-radius: 20px;
            padding: 2.5rem 2rem;
            position: relative;
        }

        body.light .auth-card {
            background: var(--bg-card-light);
            border-color: var(--border-light);
            box-shadow: 0 4px 32px rgba(0,0,0,0.08);
        }

        .auth-tabs {
            display: flex;
            gap: 0;
            margin-bottom: 2rem;
            background: var(--bg-card2);
            border-radius: var(--radius-sm);
            padding: 3px;
        }

        body.light .auth-tabs {
            background: var(--bg-card2-light);
        }

        .auth-tab {
            flex: 1;
            text-align: center;
            padding: 0.5rem;
            border-radius: calc(var(--radius-sm) - 2px);
            font-size: 0.85rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
            color: var(--text-secondary-dark);
        }

        body.light .auth-tab {
            color: var(--text-secondary-light);
        }

        .auth-tab.active {
            background: var(--accent);
            color: white;
        }
    </style>
</head>
<body>
    <div class="auth-bg">
        <div class="auth-glow"></div>
        <!-- Top nav -->
        <div style="position:fixed;top:0;left:0;right:0;padding:1rem 1.5rem;display:flex;align-items:center;justify-content:space-between;z-index:10;">
            <a asp-controller="Home" asp-action="Index" style="display:flex;align-items:center;gap:0.5rem;font-family:'Syne',sans-serif;font-weight:800;font-size:1rem;">
                <div class="logo-icon">₦</div> FinTrack
            </a>
            <button class="icon-btn theme-toggle-btn">
                <svg class="theme-icon-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M17.657 17.657l-.707-.707M6.343 6.343l-.707-.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" /></svg>
                <svg class="theme-icon-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="display:none"><path d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" /></svg>
            </button>
        </div>

        <div class="auth-card fade-up">
            <div style="text-align:center;margin-bottom:1.75rem;">
                <div class="logo-icon" style="margin:0 auto 0.75rem;width:44px;height:44px;font-size:20px;">₦</div>
                <h1 style="font-size:1.4rem;margin-bottom:0.25rem;">Welcome back</h1>
                <p style="font-size:0.85rem;color:var(--text-secondary-dark);">Sign in to your FinTrack account</p>
            </div>

            <div class="auth-tabs">
                <div class="auth-tab active">Sign In</div>
                <a class="auth-tab" asp-controller="Account" asp-action="Register">Register</a>
            </div>

            <form asp-action="Login" asp-controller="Account" method="post">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" style="color:var(--accent);font-size:0.85rem;margin-bottom:1rem;"></div>

                <div>
                    <input asp-for="Email" class="input-field" placeholder="Email address" />
                    <span asp-validation-for="Email" style="color:var(--accent);font-size:0.8rem;"></span>
                </div>

                <div style="margin-top: 0.5rem;">
                    <input asp-for="Password" class="input-field" placeholder="Password" />
                    <span asp-validation-for="Password" style="color:var(--accent);font-size:0.8rem;"></span>
                </div>

                <button type="submit" class="btn-primary" style="width:100%;justify-content:center;margin-top:0.5rem; border-radius:10px; padding:10px;">Sign In</button>
            </form>

            <div class="divider"></div>
            <p style="text-align:center;font-size:0.82rem;color:var(--text-secondary-dark);">
                Don't have an account? <a asp-controller="Account" asp-action="Register" style="color:var(--accent);font-weight:600;">Create one</a>
            </p>
        </div>
    </div>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.21.0/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js"></script>

    <script src="~/js/icons.js"></script>
    <script src="~/js/animations.js"></script>
    <script src="~/js/main.js"></script>
</body>
</html>

