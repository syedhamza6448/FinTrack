@model FinTrack.Models.ViewModels.ForgotPasswordViewModel
@{
    Layout = null;
    ViewData["Title"] = "Forgot Password";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Forgot Password — FinTrack</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="~/css/style.css" />
    <style>
        .auth-bg {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 5rem 2rem 2rem;
        }

        .auth-card {
            width: 100%;
            max-width: 420px;
            background: var(--bg-card);
            border: 1px solid var(--border-dark);
            border-radius: 20px;
            padding: 2.5rem 2rem;
        }

        body.light .auth-card {
            background: var(--bg-card-light);
            border-color: var(--border-light);
            box-shadow: 0 4px 32px rgba(0,0,0,0.08);
        }
    </style>
</head>
<body>
    <div class="auth-bg">
        <div style="position:fixed;top:0;left:0;right:0;padding:1rem 1.5rem;display:flex;align-items:center;justify-content:space-between;z-index:10;">
            <a asp-controller="Home" asp-action="Index" style="display:flex;align-items:center;gap:0.5rem;font-family:'Syne',sans-serif;font-weight:800;font-size:1rem;">
                <div class="logo-icon">₦</div> FinTrack
            </a>
            <button class="icon-btn theme-toggle-btn">
                <svg class="theme-icon-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M17.657 17.657l-.707-.707M6.343 6.343l-.707-.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" /></svg>
                <svg class="theme-icon-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="display:none"><path d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" /></svg>
            </button>
        </div>
        <div class="auth-card fade-up">
            <a asp-controller="Account" asp-action="Login" style="display:inline-flex;align-items:center;gap:0.4rem;font-size:0.82rem;color:var(--text-secondary-dark);margin-bottom:1.5rem;">
                ← Back to login
            </a>
            <div style="margin-bottom:1.75rem;">
                <div style="width:44px;height:44px;background:var(--accent-glow);border-radius:10px;display:flex;align-items:center;justify-content:center;margin-bottom:1rem;color:var(--accent);">
                    <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" /></svg>
                </div>
                <h1 style="font-size:1.4rem;margin-bottom:0.25rem;">Reset your password</h1>
                <p style="font-size:0.85rem;color:var(--text-secondary-dark);">Enter your email and we'll send a reset link.</p>
            </div>
            @if (TempData["SuccessMessage"] != null)
            {
                <div id="success" style="background:rgba(34,197,94,0.08);border:1px solid rgba(34,197,94,0.2);border-radius:12px;padding:1.25rem;text-align:center;margin-bottom:1rem;">
                    <div style="color:#22c55e;font-weight:600;margin-bottom:0.25rem;">Check your inbox</div>
                    <div style="color:var(--text-secondary-dark);font-size:0.85rem;">@TempData["SuccessMessage"]</div>
                </div>
            }

            <form asp-action="ForgotPassword" asp-controller="Account" method="post" style="display:flex;flex-direction:column;gap:1rem;">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" style="color:var(--accent);font-size:0.85rem;padding:0.5rem;background:rgba(244,63,94,0.08);border-radius:8px;"></div>

                <div>
                    <label class="input-label" asp-for="Email">Email Address</label>
                    <input asp-for="Email" class="input-field" placeholder="you@example.com" />
                    <span asp-validation-for="Email" style="color:var(--accent);font-size:0.78rem;margin-top:0.25rem;display:block;"></span>
                </div>

                <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;">
                    Send Reset Link
                </button>
            </form>
        </div>
    </div>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.21.0/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js"></script>

    <script src="~/js/icons.js"></script>
    <script src="~/js/animations.js"></script>
    <script src="~/js/main.js"></script>
</body>
</html>
