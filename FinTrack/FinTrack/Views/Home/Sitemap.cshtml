@{
    ViewData["Title"] = "Sitemap";
}

<style>
    .sitemap-container {
        max-width: 1100px;
        margin: 0 auto;
    }

    /* ── Tree lines ── */
    .tree-root {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0;
    }

    .tree-node-box {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        padding: 0.65rem 1.25rem;
        border-radius: 10px;
        font-size: 0.85rem;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.2s;
        white-space: nowrap;
    }

        .tree-node-box:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 16px rgba(0,0,0,0.2);
        }

    .connector-v {
        width: 2px;
        height: 32px;
        background: var(--border-dark);
        margin: 0 auto;
    }

    .connector-h-wrap {
        display: flex;
        align-items: flex-start;
        justify-content: center;
        position: relative;
        width: 100%;
    }

    .connector-h-line {
        position: absolute;
        top: 0;
        height: 2px;
        background: var(--border-dark);
    }

    .branch-col {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0;
        flex: 1;
    }

    .branch-connector-top {
        width: 2px;
        height: 32px;
        background: var(--border-dark);
    }

    /* ── Section labels ── */
    .section-label {
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--text-secondary-dark);
        margin-bottom: 0.75rem;
        text-align: center;
    }

    /* ── Cards ── */
    .sitemap-section {
        background: var(--bg-card);
        border: 1px solid var(--border-dark);
        border-radius: 14px;
        padding: 1.25rem;
        margin-bottom: 1.25rem;
    }

    .sitemap-section-title {
        font-size: 0.78rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.07em;
        color: var(--text-secondary-dark);
        margin-bottom: 1rem;
        padding-bottom: 0.6rem;
        border-bottom: 1px solid var(--border-dark);
    }

    .sitemap-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
        gap: 0.75rem;
    }

    .sitemap-node {
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
        padding: 0.75rem;
        background: var(--bg-card2);
        border: 1px solid var(--border-dark);
        border-radius: 10px;
        text-decoration: none;
        transition: all 0.15s;
    }

        .sitemap-node:hover {
            border-color: var(--accent);
            transform: translateY(-1px);
        }

    .sitemap-node-title {
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--text-primary-dark);
    }

    .sitemap-node-desc {
        font-size: 0.72rem;
        color: var(--text-secondary-dark);
        line-height: 1.4;
    }

    .sitemap-node-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        font-size: 0.65rem;
        font-weight: 600;
        padding: 0.15rem 0.45rem;
        border-radius: 99px;
        width: fit-content;
        margin-top: 0.15rem;
    }

    @@media (max-width: 640px) {
        .sitemap-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }
</style>

<div class="page-header">
    <h1>Sitemap</h1>
    <p>Complete structure and navigation flow of FinTrack</p>
</div>

<div class="sitemap-container">

    <!-- ── Visual Flow Diagram ── -->
    <div class="sitemap-section" style="margin-bottom:2rem;">
        <div class="sitemap-section-title">Application Flow</div>

        <!-- Root: Landing -->
        <div class="tree-root">
            <a asp-controller="Home" asp-action="Index"
               class="tree-node-box"
               style="background:rgba(244,63,94,0.12);border:1.5px solid var(--accent);color:var(--accent);">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z" /></svg>
                Landing Page
            </a>

            <div class="connector-v"></div>

            <!-- Auth Split -->
            <div style="display:flex;gap:3rem;align-items:flex-start;justify-content:center;position:relative;width:100%;">
                <!-- H line -->
                <div style="position:absolute;top:0;left:50%;transform:translateX(-50%);width:200px;height:2px;background:var(--border-dark);"></div>

                <!-- Register -->
                <div style="display:flex;flex-direction:column;align-items:center;">
                    <div class="branch-connector-top"></div>
                    <a asp-controller="Account" asp-action="Register"
                       class="tree-node-box"
                       style="background:rgba(59,130,246,0.1);border:1.5px solid #3b82f6;color:#3b82f6;">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 00-4-4H6a4 4 0 00-4 4v2" /><circle cx="9" cy="7" r="4" /><line x1="19" y1="8" x2="19" y2="14" /><line x1="22" y1="11" x2="16" y2="11" /></svg>
                        Register
                    </a>
                </div>

                <!-- Login -->
                <div style="display:flex;flex-direction:column;align-items:center;">
                    <div class="branch-connector-top"></div>
                    <a asp-controller="Account" asp-action="Login"
                       class="tree-node-box"
                       style="background:rgba(34,197,94,0.1);border:1.5px solid #22c55e;color:#22c55e;">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 3h4a2 2 0 012 2v14a2 2 0 01-2 2h-4" /><polyline points="10 17 15 12 10 7" /><line x1="15" y1="12" x2="3" y2="12" /></svg>
                        Login
                    </a>
                </div>
            </div>

            <div class="connector-v"></div>

            <!-- Dashboard -->
            <a asp-controller="Dashboard" asp-action="Index"
               class="tree-node-box"
               style="background:rgba(139,92,246,0.12);border:1.5px solid #8b5cf6;color:#8b5cf6;">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="1.5" /><rect x="14" y="3" width="7" height="7" rx="1.5" /><rect x="3" y="14" width="7" height="7" rx="1.5" /><rect x="14" y="14" width="7" height="7" rx="1.5" /></svg>
                Dashboard
            </a>

            <div class="connector-v"></div>

            <!-- Main feature branches -->
            <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:0.75rem;width:100%;position:relative;">
                <!-- H line across top -->
                <div style="position:absolute;top:0;left:12.5%;width:75%;height:2px;background:var(--border-dark);"></div>

                @{
                    var branches = new[]
                    {
                                ("Transactions", "Transactions", "#f97316", "rgba(249,115,22,0.1)", "M7 16V4m0 0L3 8m4-4l4 4M17 8v12m0 0l4-4m-4 4l-4-4"),
                                ("Expenses", "Expenses", "#f43f5e", "rgba(244,63,94,0.1)", "M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"),
                                ("Budget", "Budget", "#eab308", "rgba(234,179,8,0.1)", "M9 7H6a2 2 0 00-2 2v9a2 2 0 002 2h12a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1-4h-4a1 1 0 00-1 1v4h6V4a1 1 0 00-1-1z"),
                                ("Savings", "Savings", "#22c55e", "rgba(34,197,94,0.1)", "M19 5c-1.5 0-2.8 1.4-3 2-3.5 1.5-11 2.2-11 10 0 3.9 3.1 7 7 7h3"),
                                ("Investments", "Investments", "#3b82f6", "rgba(59,130,246,0.1)", "M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"),
                                ("Debt", "Debt", "#ec4899", "rgba(236,72,153,0.1)", "M1 4h22v4H1zM1 10h23M1 10v10h22V10"),
                                ("Reports", "Reports", "#14b8a6", "rgba(20,184,166,0.1)", "M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"),
                                ("Notifications", "Notifications", "#f43f5e", "rgba(244,63,94,0.1)", "M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9M13.73 21a2 2 0 01-3.46 0"),
                                };
                }

                @foreach (var (ctrl, label, color, bg, path) in branches)
                {
                    <div style="display:flex;flex-direction:column;align-items:center;">
                        <div class="branch-connector-top"></div>
                        <a asp-controller="@ctrl" asp-action="Index"
                           class="tree-node-box"
                           style="background:@bg;border:1.5px solid @color;color:@color;font-size:0.78rem;padding:0.5rem 0.75rem;width:100%;justify-content:center;">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="@path" /></svg>
                            @label
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- ── Full Page Directory ── -->
    <!-- Auth -->
    <div class="sitemap-section">
        <div class="sitemap-section-title">🔐 Authentication</div>
        <div class="sitemap-grid">
            <a asp-controller="Home" asp-action="Index" class="sitemap-node">
                <div class="sitemap-node-title">Landing Page</div>
                <div class="sitemap-node-desc">Welcome page with app overview</div>
                <span class="sitemap-node-badge" style="background:rgba(244,63,94,0.1);color:var(--accent);">Public</span>
            </a>
            <a asp-controller="Account" asp-action="Register" class="sitemap-node">
                <div class="sitemap-node-title">Register</div>
                <div class="sitemap-node-desc">Create a new account</div>
                <span class="sitemap-node-badge" style="background:rgba(244,63,94,0.1);color:var(--accent);">Public</span>
            </a>
            <a asp-controller="Account" asp-action="Login" class="sitemap-node">
                <div class="sitemap-node-title">Login</div>
                <div class="sitemap-node-desc">Sign in to your account</div>
                <span class="sitemap-node-badge" style="background:rgba(244,63,94,0.1);color:var(--accent);">Public</span>
            </a>
            <div class="sitemap-node" style="cursor:default;">
                <div class="sitemap-node-title">Logout</div>
                <div class="sitemap-node-desc">Sign out and end session</div>
                <span class="sitemap-node-badge" style="background:rgba(234,179,8,0.1);color:#eab308;">Auth Required</span>
            </div>
        </div>
    </div>

    <!-- Dashboard -->
    <div class="sitemap-section">
        <div class="sitemap-section-title">📊 Dashboard</div>
        <div class="sitemap-grid">
            <a asp-controller="Dashboard" asp-action="Index" class="sitemap-node">
                <div class="sitemap-node-title">Overview</div>
                <div class="sitemap-node-desc">Income, expenses, net balance, spending chart, budget status</div>
                <span class="sitemap-node-badge" style="background:rgba(139,92,246,0.1);color:#8b5cf6;">Main Hub</span>
            </a>
        </div>
    </div>

    <!-- Finance Management -->
    <div class="sitemap-section">
        <div class="sitemap-section-title">💰 Finance Management</div>
        <div class="sitemap-grid">
            <a asp-controller="Categories" asp-action="Index" class="sitemap-node">
                <div class="sitemap-node-title">Categories</div>
                <div class="sitemap-node-desc">Create and manage income/expense categories with icons and colors</div>
                <span class="sitemap-node-badge" style="background:rgba(59,130,246,0.1);color:#3b82f6;">CRUD</span>
            </a>
            <a asp-controller="Transactions" asp-action="Index" class="sitemap-node">
                <div class="sitemap-node-title">Transactions</div>
                <div class="sitemap-node-desc">Log income and expenses, filter by type/category/month</div>
                <span class="sitemap-node-badge" style="background:rgba(249,115,22,0.1);color:#f97316;">CRUD</span>
            </a>
            <a asp-controller="Expenses" asp-action="Index" class="sitemap-node">
                <div class="sitemap-node-title">Expenses</div>
                <div class="sitemap-node-desc">Expense-only view with category breakdown and top expenses</div>
                <span class="sitemap-node-badge" style="background:rgba(244,63,94,0.1);color:#f43f5e;">CRUD</span>
            </a>
            <a asp-controller="Budget" asp-action="Index" class="sitemap-node">
                <div class="sitemap-node-title">Budget</div>
                <div class="sitemap-node-desc">Set monthly budgets per category with progress tracking</div>
                <span class="sitemap-node-badge" style="background:rgba(234,179,8,0.1);color:#eab308;">CRUD</span>
            </a>
        </div>
    </div>

    <!-- Goals & Investments -->
    <div class="sitemap-section">
        <div class="sitemap-section-title">🎯 Goals & Investments</div>
        <div class="sitemap-grid">
            <a asp-controller="Savings" asp-action="Index" class="sitemap-node">
                <div class="sitemap-node-title">Savings Goals</div>
                <div class="sitemap-node-desc">Create goals, add funds, track progress with pause/resume</div>
                <span class="sitemap-node-badge" style="background:rgba(34,197,94,0.1);color:#22c55e;">CRUD</span>
            </a>
            <a asp-controller="Investments" asp-action="Index" class="sitemap-node">
                <div class="sitemap-node-title">Investments</div>
                <div class="sitemap-node-desc">Track stocks, bonds, real estate portfolio with gain/loss</div>
                <span class="sitemap-node-badge" style="background:rgba(59,130,246,0.1);color:#3b82f6;">CRUD</span>
            </a>
            <a asp-controller="Debt" asp-action="Index" class="sitemap-node">
                <div class="sitemap-node-title">Debt Management</div>
                <div class="sitemap-node-desc">Track loans, make payments, monitor payoff progress</div>
                <span class="sitemap-node-badge" style="background:rgba(236,72,153,0.1);color:#ec4899;">CRUD</span>
            </a>
        </div>
    </div>

    <!-- Insights -->
    <div class="sitemap-section">
        <div class="sitemap-section-title">📈 Insights & Alerts</div>
        <div class="sitemap-grid">
            <a asp-controller="Reports" asp-action="Index" class="sitemap-node">
                <div class="sitemap-node-title">Reports</div>
                <div class="sitemap-node-desc">6-month trends, spending breakdown, budget performance charts</div>
                <span class="sitemap-node-badge" style="background:rgba(20,184,166,0.1);color:#14b8a6;">Analytics</span>
            </a>
            <a asp-controller="Notifications" asp-action="Index" class="sitemap-node">
                <div class="sitemap-node-title">Notifications</div>
                <div class="sitemap-node-desc">Auto-generated budget, savings and debt alerts</div>
                <span class="sitemap-node-badge" style="background:rgba(244,63,94,0.1);color:#f43f5e;">Alerts</span>
            </a>
        </div>
    </div>

    <!-- Education -->
    <div class="sitemap-section">
        <div class="sitemap-section-title">🎓 Education</div>
        <div class="sitemap-grid">
            <a asp-controller="Education" asp-action="Index" class="sitemap-node">
                <div class="sitemap-node-title">Financial Education</div>
                <div class="sitemap-node-desc">Tips, tutorials and financial literacy resources</div>
                <span class="sitemap-node-badge" style="background:rgba(234,179,8,0.1);color:#eab308;">Resources</span>
            </a>
            <a asp-controller="Education" asp-action="Index" class="sitemap-node">
                <div class="sitemap-node-title">Debt Calculator</div>
                <div class="sitemap-node-desc">Calculate debt payoff timeline and interest</div>
                <span class="sitemap-node-badge" style="background:rgba(234,179,8,0.1);color:#eab308;">Tool</span>
            </a>
            <a asp-controller="Education" asp-action="Index" class="sitemap-node">
                <div class="sitemap-node-title">Savings Calculator</div>
                <div class="sitemap-node-desc">Calculate savings rate and growth over time</div>
                <span class="sitemap-node-badge" style="background:rgba(234,179,8,0.1);color:#eab308;">Tool</span>
            </a>
            <a asp-controller="Education" asp-action="Index" class="sitemap-node">
                <div class="sitemap-node-title">Investment Simulator</div>
                <div class="sitemap-node-desc">Simulate compound growth on investments</div>
                <span class="sitemap-node-badge" style="background:rgba(234,179,8,0.1);color:#eab308;">Tool</span>
            </a>
        </div>
    </div>

    <!-- Account -->
    <div class="sitemap-section">
        <div class="sitemap-section-title">⚙️ Account</div>
        <div class="sitemap-grid">
            <a asp-controller="Settings" asp-action="Index" class="sitemap-node">
                <div class="sitemap-node-title">Profile Settings</div>
                <div class="sitemap-node-desc">Update name and email address</div>
                <span class="sitemap-node-badge" style="background:rgba(148,163,184,0.1);color:#94a3b8;">Settings</span>
            </a>
            <a asp-controller="Settings" asp-action="Index" class="sitemap-node">
                <div class="sitemap-node-title">Change Password</div>
                <div class="sitemap-node-desc">Update account password securely</div>
                <span class="sitemap-node-badge" style="background:rgba(148,163,184,0.1);color:#94a3b8;">Settings</span>
            </a>
            <a asp-controller="Settings" asp-action="Index" class="sitemap-node">
                <div class="sitemap-node-title">Danger Zone</div>
                <div class="sitemap-node-desc">Permanently delete account and all data</div>
                <span class="sitemap-node-badge" style="background:rgba(244,63,94,0.1);color:#f43f5e;">Destructive</span>
            </a>
            <a asp-controller="Home" asp-action="Sitemap" class="sitemap-node">
                <div class="sitemap-node-title">Sitemap</div>
                <div class="sitemap-node-desc">Full application structure and navigation flow</div>
                <span class="sitemap-node-badge" style="background:rgba(148,163,184,0.1);color:#94a3b8;">This Page</span>
            </a>
        </div>
    </div>

    <!-- Legend -->
    <div class="card" style="margin-top:1.25rem;">
        <div class="sitemap-section-title" style="margin-bottom:0.75rem;">Legend</div>
        <div style="display:flex;flex-wrap:wrap;gap:0.75rem;">
            <span class="sitemap-node-badge" style="background:rgba(244,63,94,0.1);color:var(--accent);font-size:0.75rem;padding:0.3rem 0.75rem;">Public — No login required</span>
            <span class="sitemap-node-badge" style="background:rgba(234,179,8,0.1);color:#eab308;font-size:0.75rem;padding:0.3rem 0.75rem;">Auth Required — Login needed</span>
            <span class="sitemap-node-badge" style="background:rgba(59,130,246,0.1);color:#3b82f6;font-size:0.75rem;padding:0.3rem 0.75rem;">CRUD — Create, Read, Update, Delete</span>
            <span class="sitemap-node-badge" style="background:rgba(20,184,166,0.1);color:#14b8a6;font-size:0.75rem;padding:0.3rem 0.75rem;">Analytics — Data visualization</span>
            <span class="sitemap-node-badge" style="background:rgba(234,179,8,0.1);color:#eab308;font-size:0.75rem;padding:0.3rem 0.75rem;">Tool — Interactive calculator</span>
            <span class="sitemap-node-badge" style="background:rgba(139,92,246,0.1);color:#8b5cf6;font-size:0.75rem;padding:0.3rem 0.75rem;">Main Hub — Central navigation point</span>
        </div>
    </div>

</div>