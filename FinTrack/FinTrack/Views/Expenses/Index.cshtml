@model FinTrack.Models.ViewModels.ExpenseViewModel
@{
    ViewData["Title"] = "Expenses";
    var months = System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.MonthNames
        .Take(12).Select((m, i) => new { Name = m, Value = i + 1 });
    var monthName = System.Globalization.CultureInfo.CurrentCulture
        .DateTimeFormat.GetMonthName(Model.SelectedMonth);
}

<style>
    .exp-grid {
        display: grid;
        grid-template-columns: 1fr 320px;
        gap: 1.25rem;
        align-items: start;
    }

    .exp-form-sticky {
        position: sticky;
        top: 76px;
    }

    .exp-stats {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1.25rem;
        margin-bottom: 1.25rem;
    }

    .exp-bottom-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.25rem;
        margin-top: 1.25rem;
    }

    .col-category, .col-date {
        display: table-cell;
    }

    @@media (max-width: 1024px) {
        .exp-grid {
            grid-template-columns: 1fr;
        }

        .exp-form-sticky {
            position: static;
        }

        .exp-bottom-grid {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 640px) {
        .exp-stats {
            grid-template-columns: repeat(2, 1fr);
        }

        .col-category, .col-date {
            display: none;
        }
    }
</style>

<div class="page-header">
    <h1>Expenses</h1>
    <p>Track and analyse your spending</p>
</div>

@if (TempData["Success"] != null)
{
    <div style="background:rgba(34,197,94,0.08);border:1px solid rgba(34,197,94,0.2);border-radius:10px;padding:0.75rem 1rem;margin-bottom:1.25rem;color:#22c55e;font-size:0.875rem;">
        ✓ @TempData["Success"]
    </div>
}
@if (TempData["Error"] != null)
{
    <div style="background:rgba(244,63,94,0.08);border:1px solid rgba(244,63,94,0.2);border-radius:10px;padding:0.75rem 1rem;margin-bottom:1.25rem;color:var(--accent);font-size:0.875rem;">
        ✕ @TempData["Error"]
    </div>
}

<!-- Summary Stats -->
<div class="exp-stats">
    <div class="card stat-card">
        <div class="stat-label">Total Expenses</div>
        <div class="stat-value" style="color:var(--accent);">₦@Model.TotalExpenses.ToString("N0")</div>
    </div>
    <div class="card stat-card">
        <div class="stat-label">Largest Expense</div>
        <div class="stat-value">₦@Model.LargestExpense.ToString("N0")</div>
    </div>
    <div class="card stat-card">
        <div class="stat-label">Top Category</div>
        <div class="stat-value" style="font-size:1rem;">@Model.TopCategory</div>
    </div>
    <div class="card stat-card">
        <div class="stat-label">Transactions</div>
        <div class="stat-value">@Model.TransactionCount</div>
    </div>
</div>

<!-- Month/Category Filter -->
<form method="get" asp-action="Index" asp-controller="Expenses"
      style="display:flex;gap:0.6rem;flex-wrap:wrap;align-items:center;margin-bottom:1.25rem;">
    <select name="month" class="input-field" style="width:auto;padding:0.35rem 0.75rem;font-size:0.82rem;">
        @foreach (var m in months)
        {
            <option value="@m.Value" selected="@(Model.SelectedMonth == m.Value)">@m.Name</option>
        }
    </select>
    <select name="year" class="input-field" style="width:auto;padding:0.35rem 0.75rem;font-size:0.82rem;">
        @for (int y = DateTime.Now.Year; y >= DateTime.Now.Year - 3; y--)
        {
            <option value="@y" selected="@(Model.SelectedYear == y)">@y</option>
        }
    </select>
    <select name="categoryId" class="input-field" style="width:auto;padding:0.35rem 0.75rem;font-size:0.82rem;">
        <option value="0">All Categories</option>
        @foreach (var cat in Model.Categories)
        {
            <option value="@cat.Id" selected="@(ViewBag.SelectedCategory == cat.Id)">@cat.Name</option>
        }
    </select>
    <button type="submit" class="btn-primary"
            style="padding:0.35rem 1rem;font-size:0.82rem;border-radius:8px;">
        Filter
    </button>
    <a asp-action="Index" asp-controller="Expenses"
       style="font-size:0.82rem;color:var(--text-secondary-dark);align-self:center;">
        Clear
    </a>
</form>

<div class="exp-grid">

    <!-- ── Expense List ── -->
    <div class="card">
        <h3 style="font-size:0.95rem;margin-bottom:1.25rem;">
            Expenses — @monthName @Model.SelectedYear
        </h3>

        @if (!Model.Transactions.Any())
        {
            <div style="text-align:center;padding:3rem 1rem;color:var(--text-secondary-dark);">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25"
                     style="margin:0 auto 1rem;display:block;opacity:0.4;">
                    <circle cx="9" cy="21" r="1" />
                    <circle cx="20" cy="21" r="1" />
                    <path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 001.95-1.57l1.65-8.42H6" />
                </svg>
                <p style="font-size:0.9rem;margin-bottom:0.25rem;">No expenses this month</p>
                <p style="font-size:0.8rem;">Add your first expense using the form</p>
            </div>
        }
        else
        {
            <div style="overflow-x:auto;">
                <table style="width:100%;border-collapse:collapse;font-size:0.855rem;">
                    <thead>
                        <tr style="border-bottom:1px solid var(--border-dark);">
                            <th style="text-align:left;padding:0.5rem 0.75rem;font-weight:600;font-size:0.75rem;text-transform:uppercase;letter-spacing:0.05em;color:var(--text-secondary-dark);">Description</th>
                            <th class="col-category" style="text-align:left;padding:0.5rem 0.75rem;font-weight:600;font-size:0.75rem;text-transform:uppercase;letter-spacing:0.05em;color:var(--text-secondary-dark);">Category</th>
                            <th class="col-date" style="text-align:left;padding:0.5rem 0.75rem;font-weight:600;font-size:0.75rem;text-transform:uppercase;letter-spacing:0.05em;color:var(--text-secondary-dark);">Date</th>
                            <th style="text-align:right;padding:0.5rem 0.75rem;font-weight:600;font-size:0.75rem;text-transform:uppercase;letter-spacing:0.05em;color:var(--text-secondary-dark);">Amount</th>
                            <th style="padding:0.5rem 0.75rem;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var tx in Model.Transactions)
                        {
                            <tr style="border-bottom:1px solid var(--border-dark);transition:background 0.15s;"
                                onmouseover="this.style.background='var(--bg-card2)'"
                                onmouseout="this.style.background='none'">
                                <td style="padding:0.75rem;">
                                    <div style="display:flex;align-items:center;gap:0.6rem;">
                                        <div style="width:32px;height:32px;border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0;background:rgba(244,63,94,0.1);color:var(--accent);">
                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <circle cx="9" cy="21" r="1" />
                                                <circle cx="20" cy="21" r="1" />
                                                <path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 001.95-1.57l1.65-8.42H6" />
                                            </svg>
                                        </div>
                                        <div>
                                            <div style="font-weight:500;">@tx.Description</div>
                                            @if (!string.IsNullOrEmpty(tx.Notes))
                                            {
                                                <div style="font-size:0.75rem;color:var(--text-secondary-dark);">@tx.Notes</div>
                                            }
                                            <div class="mobile-meta" style="display:none;font-size:0.72rem;color:var(--text-secondary-dark);margin-top:0.15rem;">
                                                @tx.Category?.Name · @tx.Date.ToString("MMM dd, yyyy")
                                            </div>
                                        </div>
                                    </div>
                                </td>
                                <td class="col-category" style="padding:0.75rem;">
                                    <span style="display:inline-flex;align-items:center;gap:0.35rem;background:var(--bg-card2);border-radius:99px;padding:0.2rem 0.6rem;font-size:0.78rem;">
                                        <span style="width:6px;height:6px;border-radius:50%;background:@(tx.Category?.Color ?? "#94a3b8");"></span>
                                        @tx.Category?.Name
                                    </span>
                                </td>
                                <td class="col-date" style="padding:0.75rem;color:var(--text-secondary-dark);font-size:0.82rem;">
                                    @tx.Date.ToString("MMM dd, yyyy")
                                </td>
                                <td style="padding:0.75rem;text-align:right;font-weight:600;color:var(--accent);">
                                    -₦@tx.Amount.ToString("N0")
                                </td>
                                <td style="padding:0.75rem;text-align:right;">
                                    <form asp-action="Delete" asp-controller="Expenses" method="post" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@tx.Id" />
                                        <button type="submit"
                                                onclick="return confirm('Delete this expense?')"
                                                style="background:none;border:none;cursor:pointer;color:var(--text-secondary-dark);padding:0.25rem;border-radius:6px;transition:color 0.15s;"
                                                onmouseover="this.style.color='var(--accent)'"
                                                onmouseout="this.style.color='var(--text-secondary-dark)'"
                                                title="Delete">
                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <polyline points="3 6 5 6 21 6" />
                                                <path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6" />
                                                <path d="M10 11v6M14 11v6" />
                                                <path d="M9 6V4a1 1 0 011-1h4a1 1 0 011 1v2" />
                                            </svg>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

    <!-- ── Add Expense Form ── -->
    <div class="card exp-form-sticky">
        <h3 style="font-size:0.95rem;margin-bottom:1.25rem;">Add Expense</h3>

        <form asp-action="Create" asp-controller="Expenses" method="post"
              style="display:flex;flex-direction:column;gap:1rem;">
            @Html.AntiForgeryToken()
            <input type="hidden" name="NewTransaction.Type" value="Expense" />

            <div asp-validation-summary="ModelOnly"
                 style="color:var(--accent);font-size:0.82rem;padding:0.5rem;background:rgba(244,63,94,0.08);border-radius:8px;">
            </div>

            <div>
                <label class="input-label" asp-for="NewTransaction.Description">Description</label>
                <input asp-for="NewTransaction.Description" class="input-field"
                       placeholder="e.g. Grocery shopping" />
                <span asp-validation-for="NewTransaction.Description"
                      style="color:var(--accent);font-size:0.78rem;"></span>
            </div>

            <div>
                <label class="input-label" asp-for="NewTransaction.Amount">Amount (₦)</label>
                <input asp-for="NewTransaction.Amount" class="input-field" type="number"
                       placeholder="0.00" step="0.01" min="0.01" />
                <span asp-validation-for="NewTransaction.Amount"
                      style="color:var(--accent);font-size:0.78rem;"></span>
            </div>

            <div>
                <label class="input-label" asp-for="NewTransaction.CategoryId">Category</label>
                <select asp-for="NewTransaction.CategoryId" class="input-field">
                    <option value="">Select category...</option>
                    @foreach (var cat in Model.Categories)
                    {
                        <option value="@cat.Id">@cat.Name</option>
                    }
                </select>
                <span asp-validation-for="NewTransaction.CategoryId"
                      style="color:var(--accent);font-size:0.78rem;"></span>
            </div>

            <div>
                <label class="input-label" asp-for="NewTransaction.Date">Date</label>
                <input asp-for="NewTransaction.Date" class="input-field" type="date"
                       value="@DateTime.Today.ToString("yyyy-MM-dd")" />
                <span asp-validation-for="NewTransaction.Date"
                      style="color:var(--accent);font-size:0.78rem;"></span>
            </div>

            <div>
                <label class="input-label" asp-for="NewTransaction.Notes">Notes (optional)</label>
                <input asp-for="NewTransaction.Notes" class="input-field"
                       placeholder="Any extra details..." />
            </div>

            <button type="submit" class="btn-primary"
                    style="width:100%;justify-content:center;padding:10px;border-radius:10px;">
                + Add Expense
            </button>
        </form>
    </div>

</div>

<!-- ── Category Breakdown + Top Expenses ── -->
<div class="exp-bottom-grid">

    <!-- Category Breakdown -->
    <div class="card">
        <h3 style="font-size:0.9rem;margin-bottom:1rem;">
            Spending by Category — @monthName @Model.SelectedYear
        </h3>
        @if (!Model.CategoryBreakdown.Any())
        {
            <p style="color:var(--text-secondary-dark);font-size:0.85rem;text-align:center;padding:1.5rem 0;">
                No data for this month
            </p>
        }
        else
        {
            <div style="display:flex;flex-direction:column;gap:0.85rem;">
                @foreach (var cat in Model.CategoryBreakdown)
                {
                    <div>
                        <div style="display:flex;justify-content:space-between;font-size:0.8rem;margin-bottom:0.3rem;">
                            <div style="display:flex;align-items:center;gap:0.5rem;">
                                <span style="width:8px;height:8px;border-radius:50%;background:@cat.Color;flex-shrink:0;"></span>
                                <span>@cat.CategoryName</span>
                                <span style="color:var(--text-secondary-dark);font-size:0.72rem;">(@cat.Count txns)</span>
                            </div>
                            <div style="display:flex;gap:0.75rem;">
                                <span style="color:var(--text-secondary-dark);">@cat.Percentage%</span>
                                <span style="font-weight:600;">₦@cat.Amount.ToString("N0")</span>
                            </div>
                        </div>
                        <div style="height:6px;background:var(--bg-card2);border-radius:99px;overflow:hidden;">
                            <div style="height:100%;width:@(cat.Percentage)%;background:@cat.Color;border-radius:99px;transition:width 0.6s ease;"></div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <!-- Top 5 Expenses -->
    <div class="card">
        <h3 style="font-size:0.9rem;margin-bottom:1rem;">
            Top Expenses — @monthName @Model.SelectedYear
        </h3>
        @if (!Model.Transactions.Any())
        {
            <p style="color:var(--text-secondary-dark);font-size:0.85rem;text-align:center;padding:1.5rem 0;">
                No expenses recorded this month
            </p>
        }
        else
        {
            <div style="display:flex;flex-direction:column;gap:0.6rem;">
                @foreach (var (tx, index) in Model.Transactions.Take(5).Select((t, i) => (t, i + 1)))
                {
                    <div style="display:flex;align-items:center;gap:0.75rem;">
                        <span style="width:22px;height:22px;border-radius:50%;background:var(--bg-card2);display:flex;align-items:center;justify-content:center;font-size:0.7rem;font-weight:700;color:var(--text-secondary-dark);flex-shrink:0;">
                            @index
                        </span>
                        <div style="flex:1;min-width:0;">
                            <div style="font-size:0.82rem;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
                                @tx.Description
                            </div>
                            <div style="font-size:0.72rem;color:var(--text-secondary-dark);">
                                @tx.Category?.Name · @tx.Date.ToString("MMM dd")
                            </div>
                        </div>
                        <span style="font-weight:600;font-size:0.85rem;color:var(--accent);flex-shrink:0;">
                            ₦@tx.Amount.ToString("N0")
                        </span>
                    </div>
                }
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            function checkMobile() {
                const isMobile = window.innerWidth <= 640;
                document.querySelectorAll('.mobile-meta').forEach(el => {
                    el.style.display = isMobile ? 'block' : 'none';
                });
            }
            checkMobile();
            window.addEventListener('resize', checkMobile);
        });
    </script>
}