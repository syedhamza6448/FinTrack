@model FinTrack.Models.ViewModels.TransactionViewModel
@{
    ViewData["Title"] = "Transactions";
    var months = System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.MonthNames
        .Take(12).Select((m, i) => new { Name = m, Value = i + 1 });
}

<style>
    .tx-grid {
        display: grid;
        grid-template-columns: 1fr 320px;
        gap: 1.25rem;
        align-items: start;
    }

    .tx-form-sticky {
        position: sticky;
        top: 76px;
    }

    /* Hide category and date columns on small screens */
    .col-category, .col-date {
        display: table-cell;
    }

    @@media (max-width: 1024px) {
        .tx-grid {
            grid-template-columns: 1fr;
        }

        .tx-form-sticky {
            position: static;
        }
    }

    @@media (max-width: 640px) {
        .col-category, .col-date {
            display: none;
        }

        .grid-4 {
            grid-template-columns: repeat(2, 1fr) !important;
        }
    }
</style>

<div class="page-header">
    <h1>Transactions</h1>
    <p>Track every income and expense</p>
</div>

@if (TempData["Success"] != null)
{
    <div style="background:rgba(34,197,94,0.08);border:1px solid rgba(34,197,94,0.2);border-radius:10px;padding:0.75rem 1rem;margin-bottom:1.25rem;color:#22c55e;font-size:0.875rem;">
        ✓ @TempData["Success"]
    </div>
}
@if (TempData["Error"] != null)
{
    <div style="background:rgba(244,63,94,0.08);border:1px solid rgba(244,63,94,0.2);border-radius:10px;padding:0.75rem 1rem;margin-bottom:1.25rem;color:var(--accent);font-size:0.875rem;">
        ✕ @TempData["Error"]
    </div>
}

<!-- Summary Stats -->
<div class="grid-4" style="margin-bottom:1.25rem;display:grid;grid-template-columns:repeat(4,1fr);gap:1.25rem;">
    <div class="card stat-card">
        <div class="stat-label">Total Income</div>
        <div class="stat-value" style="color:#22c55e;">₦@Model.TotalIncome.ToString("N0")</div>
    </div>
    <div class="card stat-card">
        <div class="stat-label">Total Expenses</div>
        <div class="stat-value" style="color:var(--accent);">₦@Model.TotalExpenses.ToString("N0")</div>
    </div>
    <div class="card stat-card">
        <div class="stat-label">Net Balance</div>
        <div class="stat-value" style="color:@(Model.NetBalance >= 0 ? "#22c55e" : "var(--accent)");">
            ₦@Model.NetBalance.ToString("N0")
        </div>
    </div>
    <div class="card stat-card">
        <div class="stat-label">Transactions</div>
        <div class="stat-value">@Model.Transactions.Count</div>
    </div>
</div>

<div class="tx-grid">

    <!-- ── Transaction List ── -->
    <div class="card">

        <!-- Filters -->
        <form method="get" asp-action="Index" asp-controller="Transactions"
              style="display:flex;gap:0.6rem;flex-wrap:wrap;margin-bottom:1.25rem;align-items:center;">
            <select name="type" class="input-field" style="width:auto;padding:0.35rem 0.75rem;font-size:0.82rem;">
                <option value="" selected="@(ViewBag.SelectedType == "")">All Types</option>
                <option value="Income" selected="@(ViewBag.SelectedType == "Income")">Income</option>
                <option value="Expense" selected="@(ViewBag.SelectedType == "Expense")">Expense</option>
            </select>

            <select name="categoryId" class="input-field" style="width:auto;padding:0.35rem 0.75rem;font-size:0.82rem;">
                <option value="0">All Categories</option>
                @foreach (var cat in Model.Categories)
                {
                    <option value="@cat.Id" selected="@(ViewBag.SelectedCategory == cat.Id)">@cat.Name</option>
                }
            </select>

            <select name="month" class="input-field" style="width:auto;padding:0.35rem 0.75rem;font-size:0.82rem;">
                @foreach (var m in months)
                {
                    <option value="@m.Value" selected="@(ViewBag.SelectedMonth == m.Value)">@m.Name</option>
                }
            </select>

            <select name="year" class="input-field" style="width:auto;padding:0.35rem 0.75rem;font-size:0.82rem;">
                @for (int y = DateTime.Now.Year; y >= DateTime.Now.Year - 3; y--)
                {
                    <option value="@y" selected="@(ViewBag.SelectedYear == y)">@y</option>
                }
            </select>

            <button type="submit" class="btn-primary"
                    style="padding:0.35rem 1rem;font-size:0.82rem;border-radius:8px;">
                Filter
            </button>

            <a asp-action="Index" asp-controller="Transactions"
               style="font-size:0.82rem;color:var(--text-secondary-dark);align-self:center;">
                Clear
            </a>
        </form>

        <!-- Table -->
        @if (!Model.Transactions.Any())
        {
            <div style="text-align:center;padding:3rem 1rem;color:var(--text-secondary-dark);">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25"
                     style="margin:0 auto 1rem;display:block;opacity:0.4;">
                    <path d="M7 16V4m0 0L3 8m4-4l4 4M17 8v12m0 0l4-4m-4 4l-4-4" />
                </svg>
                <p style="font-size:0.9rem;margin-bottom:0.25rem;">No transactions found</p>
                <p style="font-size:0.8rem;">Add your first transaction using the form</p>
            </div>
        }
        else
        {
            <div style="overflow-x:auto;">
                <table style="width:100%;border-collapse:collapse;font-size:0.855rem;">
                    <thead>
                        <tr style="border-bottom:1px solid var(--border-dark);">
                            <th style="text-align:left;padding:0.5rem 0.75rem;font-weight:600;font-size:0.75rem;text-transform:uppercase;letter-spacing:0.05em;color:var(--text-secondary-dark);">
                                Description
                            </th>
                            <th class="col-category" style="text-align:left;padding:0.5rem 0.75rem;font-weight:600;font-size:0.75rem;text-transform:uppercase;letter-spacing:0.05em;color:var(--text-secondary-dark);">
                                Category
                            </th>
                            <th class="col-date" style="text-align:left;padding:0.5rem 0.75rem;font-weight:600;font-size:0.75rem;text-transform:uppercase;letter-spacing:0.05em;color:var(--text-secondary-dark);">
                                Date
                            </th>
                            <th style="text-align:right;padding:0.5rem 0.75rem;font-weight:600;font-size:0.75rem;text-transform:uppercase;letter-spacing:0.05em;color:var(--text-secondary-dark);">
                                Amount
                            </th>
                            <th style="padding:0.5rem 0.75rem;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var tx in Model.Transactions)
                        {
                            <tr style="border-bottom:1px solid var(--border-dark);transition:background 0.15s;"
                                onmouseover="this.style.background='var(--bg-card2)'"
                                onmouseout="this.style.background='none'">
                                <td style="padding:0.75rem;">
                                    <div style="display:flex;align-items:center;gap:0.6rem;">
                                        <div style="width:32px;height:32px;border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0;
                                                    background:@(tx.Type == "Income" ? "rgba(34,197,94,0.1)" : "rgba(244,63,94,0.1)");
                                                    color:@(tx.Type == "Income" ? "#22c55e" : "var(--accent)");">
                                            @if (tx.Type == "Income")
                                            {
                                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                    <line x1="12" y1="1" x2="12" y2="23" />
                                                    <path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6" />
                                                </svg>
                                            }
                                            else
                                            {
                                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                    <circle cx="9" cy="21" r="1" />
                                                    <circle cx="20" cy="21" r="1" />
                                                    <path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 001.95-1.57l1.65-8.42H6" />
                                                </svg>
                                            }
                                        </div>
                                        <div>
                                            <div style="font-weight:500;">@tx.Description</div>
                                            @if (!string.IsNullOrEmpty(tx.Notes))
                                            {
                                                <div style="font-size:0.75rem;color:var(--text-secondary-dark);">@tx.Notes</div>
                                            }
                                            <!-- Show category + date on mobile since columns are hidden -->
                                            <div class="mobile-meta" style="display:none;font-size:0.72rem;color:var(--text-secondary-dark);margin-top:0.15rem;">
                                                @tx.Category?.Name · @tx.Date.ToString("MMM dd, yyyy")
                                            </div>
                                        </div>
                                    </div>
                                </td>
                                <td class="col-category" style="padding:0.75rem;">
                                    <span style="display:inline-flex;align-items:center;gap:0.35rem;background:var(--bg-card2);border-radius:99px;padding:0.2rem 0.6rem;font-size:0.78rem;">
                                        <span style="width:6px;height:6px;border-radius:50%;background:@(tx.Category?.Color ?? "#94a3b8");"></span>
                                        @tx.Category?.Name
                                    </span>
                                </td>
                                <td class="col-date" style="padding:0.75rem;color:var(--text-secondary-dark);font-size:0.82rem;">
                                    @tx.Date.ToString("MMM dd, yyyy")
                                </td>
                                <td style="padding:0.75rem;text-align:right;font-weight:600;color:@(tx.Type == "Income" ? "#22c55e" : "var(--accent)");">
                                    @(tx.Type == "Income" ? "+" : "-")₦@tx.Amount.ToString("N0")
                                </td>
                                <td style="padding:0.75rem;text-align:right;">
                                    <form asp-action="Delete" asp-controller="Transactions" method="post" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@tx.Id" />
                                        <button type="submit"
                                                onclick="return confirm('Delete this transaction?')"
                                                style="background:none;border:none;cursor:pointer;color:var(--text-secondary-dark);padding:0.25rem;border-radius:6px;transition:color 0.15s;"
                                                onmouseover="this.style.color='var(--accent)'"
                                                onmouseout="this.style.color='var(--text-secondary-dark)'"
                                                title="Delete">
                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <polyline points="3 6 5 6 21 6" />
                                                <path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6" />
                                                <path d="M10 11v6M14 11v6" />
                                                <path d="M9 6V4a1 1 0 011-1h4a1 1 0 011 1v2" />
                                            </svg>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

    <!-- ── Add Transaction Form ── -->
    <div class="card tx-form-sticky">
        <h3 style="font-size:0.95rem;margin-bottom:1.25rem;">Add Transaction</h3>

        <form asp-action="Create" asp-controller="Transactions" method="post"
              style="display:flex;flex-direction:column;gap:1rem;">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly"
                 style="color:var(--accent);font-size:0.82rem;padding:0.5rem;background:rgba(244,63,94,0.08);border-radius:8px;">
            </div>

            <div>
                <label class="input-label" asp-for="NewTransaction.Type">Type</label>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.5rem;">
                    <label style="cursor:pointer;">
                        <input type="radio" name="NewTransaction.Type" value="Expense"
                               checked style="display:none;" id="typeExpense" />
                        <div class="type-btn" onclick="setType('Expense')" id="btnExpense"
                             style="text-align:center;padding:0.5rem;border-radius:8px;border:1px solid var(--accent);background:rgba(244,63,94,0.1);color:var(--accent);font-size:0.82rem;font-weight:600;cursor:pointer;">
                            Expense
                        </div>
                    </label>
                    <label style="cursor:pointer;">
                        <input type="radio" name="NewTransaction.Type" value="Income"
                               style="display:none;" id="typeIncome" />
                        <div class="type-btn" onclick="setType('Income')" id="btnIncome"
                             style="text-align:center;padding:0.5rem;border-radius:8px;border:1px solid var(--border-dark);color:var(--text-secondary-dark);font-size:0.82rem;font-weight:600;cursor:pointer;">
                            Income
                        </div>
                    </label>
                </div>
            </div>

            <div>
                <label class="input-label" asp-for="NewTransaction.Description">Description</label>
                <input asp-for="NewTransaction.Description" class="input-field" placeholder="e.g. Grocery shopping" />
                <span asp-validation-for="NewTransaction.Description" style="color:var(--accent);font-size:0.78rem;"></span>
            </div>

            <div>
                <label class="input-label" asp-for="NewTransaction.Amount">Amount (₦)</label>
                <input asp-for="NewTransaction.Amount" class="input-field" type="number"
                       placeholder="0.00" step="0.01" min="0.01" />
                <span asp-validation-for="NewTransaction.Amount" style="color:var(--accent);font-size:0.78rem;"></span>
            </div>

            <div>
                <label class="input-label" asp-for="NewTransaction.CategoryId">Category</label>
                <select asp-for="NewTransaction.CategoryId" class="input-field" id="categorySelect">
                    <option value="">Select category...</option>
                    @foreach (var cat in Model.Categories)
                    {
                        <option value="@cat.Id" data-type="@cat.Type">@cat.Name (@cat.Type)</option>
                    }
                </select>
                <span asp-validation-for="NewTransaction.CategoryId" style="color:var(--accent);font-size:0.78rem;"></span>
            </div>

            <div>
                <label class="input-label" asp-for="NewTransaction.Date">Date</label>
                <input asp-for="NewTransaction.Date" class="input-field" type="date"
                       value="@DateTime.Today.ToString("yyyy-MM-dd")" />
                <span asp-validation-for="NewTransaction.Date" style="color:var(--accent);font-size:0.78rem;"></span>
            </div>

            <div>
                <label class="input-label" asp-for="NewTransaction.Notes">Notes (optional)</label>
                <input asp-for="NewTransaction.Notes" class="input-field" placeholder="Any extra details..." />
            </div>

            <button type="submit" class="btn-primary"
                    style="width:100%;justify-content:center;padding:10px;border-radius:10px;">
                + Add Transaction
            </button>
        </form>
    </div>

</div>

@section Scripts {
    <script>
        function setType(type) {
            document.getElementById('typeExpense').checked = (type === 'Expense');
            document.getElementById('typeIncome').checked = (type === 'Income');

            const btnExpense = document.getElementById('btnExpense');
            const btnIncome = document.getElementById('btnIncome');

            if (type === 'Expense') {
                btnExpense.style.border = '1px solid var(--accent)';
                btnExpense.style.background = 'rgba(244,63,94,0.1)';
                btnExpense.style.color = 'var(--accent)';
                btnIncome.style.border = '1px solid var(--border-dark)';
                btnIncome.style.background = 'none';
                btnIncome.style.color = 'var(--text-secondary-dark)';
            } else {
                btnIncome.style.border = '1px solid #22c55e';
                btnIncome.style.background = 'rgba(34,197,94,0.1)';
                btnIncome.style.color = '#22c55e';
                btnExpense.style.border = '1px solid var(--border-dark)';
                btnExpense.style.background = 'none';
                btnExpense.style.color = 'var(--text-secondary-dark)';
            }

            const select = document.getElementById('categorySelect');
            Array.from(select.options).forEach(opt => {
                if (opt.value === '') return;
                opt.style.display = opt.dataset.type === type ? '' : 'none';
            });
            select.value = '';
        }

        document.addEventListener('DOMContentLoaded', function () {
            setType('Expense');

            // Show mobile meta (category + date) when columns are hidden
            function checkMobile() {
                const isMobile = window.innerWidth <= 640;
                document.querySelectorAll('.mobile-meta').forEach(el => {
                    el.style.display = isMobile ? 'block' : 'none';
                });
            }

            checkMobile();
            window.addEventListener('resize', checkMobile);
        });
    </script>
}